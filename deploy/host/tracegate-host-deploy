#!/usr/bin/env bash
set -euo pipefail

INSTALL_ROOT="${TRACEGATE_INSTALL_ROOT:-/opt/tracegate}"
ETC_DIR="${TRACEGATE_ETC_DIR:-/etc/tracegate}"
DEPLOY_ENV="${TRACEGATE_DEPLOY_ENV:-${ETC_DIR}/deploy.env}"
STATE_DIR="${TRACEGATE_STATE_DIR:-/var/lib/tracegate/deploy-state}"
SYSTEMD_DIR="${TRACEGATE_SYSTEMD_DIR:-/etc/systemd/system}"
SYSCTL_DIR="${TRACEGATE_SYSCTL_DIR:-/etc/sysctl.d}"
LOCAL_SBIN_DIR="${TRACEGATE_LOCAL_SBIN_DIR:-/usr/local/sbin}"
SYSTEMCTL="${TRACEGATE_SYSTEMCTL:-systemctl}"
CURL="${TRACEGATE_CURL:-curl}"
SYSCTL="${TRACEGATE_SYSCTL:-sysctl}"
PYTHON="${TRACEGATE_PYTHON:-python3}"
HEALTH_ATTEMPTS="${TRACEGATE_HEALTH_ATTEMPTS:-60}"
HEALTH_DELAY_SECONDS="${TRACEGATE_HEALTH_DELAY_SECONDS:-2}"

die() { echo "tracegate host deploy: $*" >&2; exit 2; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing command: $1"; }

load_deploy_env() {
  [ -f "${DEPLOY_ENV}" ] || die "missing deployment environment: ${DEPLOY_ENV}"
  set -a
  # shellcheck disable=SC1090
  source "${DEPLOY_ENV}"
  set +a
  case "${TRACEGATE_HOST_ROLE:-}" in
    endpoint)
      RUNTIME_ENV="${TRACEGATE_RUNTIME_ENV:-${ETC_DIR}/tracegate.env}"
      ROLE_UNITS=(
        tracegate-wireguard.service
        tracegate-agent.service
        tracegate-xray@transit.service
        tracegate-xray-ss2022.service
        tracegate-hysteria@transit.service
        tracegate-hysteria-salamander.service
        tracegate-shadowtls.service
        tracegate-wstunnel-wireguard.service
        tracegate-nginx@transit.service
        tracegate-haproxy@transit.service
        tracegate-wireguard-sync.service
        tracegate-prometheus.service
        tracegate-grafana.service
        tracegate-api.service
        tracegate-dispatcher.service
        tracegate-bot.service
        tracegate-db-backup.timer
      )
      HEALTH_URLS=(
        "${TRACEGATE_API_HEALTH_URL:-http://127.0.0.1:18080/ready}"
        "${TRACEGATE_AGENT_HEALTH_URL:-http://127.0.0.1:8070/v1/health}"
      )
      ;;
    entry)
      RUNTIME_ENV="${TRACEGATE_ENTRY_RUNTIME_ENV:-${ETC_DIR}/tracegate-entry.env}"
      ROLE_UNITS=(
        tracegate-entry-firewall.service
        tracegate-agent-entry.service
        tracegate-xray@entry.service
        tracegate-hysteria@entry.service
        tracegate-mtproto@entry.service
        tracegate-nginx@entry.service
        tracegate-haproxy@entry.service
      )
      HEALTH_URLS=("${TRACEGATE_AGENT_HEALTH_URL:-http://127.0.0.1:8070/v1/health}")
      ;;
    *) die "TRACEGATE_HOST_ROLE must be endpoint or entry" ;;
  esac
}

release_path() {
  local version="$1"
  printf '%s/releases/%s' "${INSTALL_ROOT}" "${version}"
}

validate_release() {
  local version="$1" release runtime venv mode required_file
  release="$(release_path "${version}")"
  runtime="${release}/runtime"
  venv="${release}/venv"
  [ -d "${runtime}" ] || die "missing staged runtime: ${runtime}"
  [ -x "${venv}/bin/tracegate-api" ] || die "missing staged application venv: ${venv}"
  [ -f "${RUNTIME_ENV}" ] || die "missing runtime environment: ${RUNTIME_ENV}"
  mode="$(stat -c '%a' "${RUNTIME_ENV}" 2>/dev/null || stat -f '%Lp' "${RUNTIME_ENV}")"
  case "${mode}" in 600|400) ;; *) die "${RUNTIME_ENV} must have mode 0600 or 0400" ;; esac
  if grep -En '(^|=)(REPLACE_ME|CHANGE_ME|TODO|REPLACE_WITH_)' "${RUNTIME_ENV}" "${DEPLOY_ENV}" >/dev/null 2>&1; then
    die "placeholder value found in deployment inputs"
  fi
  "${venv}/bin/python" "${runtime}/scripts/check_host_runtime.py" --root "${runtime}"
  "${venv}/bin/python" "${runtime}/scripts/check_host_deploy.py" --root "${runtime}"
  if [ -n "${TRACEGATE_PRIVATE_ROLE:-}" ]; then
    private_args=(--root "${TRACEGATE_PRIVATE_ROOT:-/var/lib/tracegate/private}" --role "${TRACEGATE_PRIVATE_ROLE}")
    if [ -n "${TRACEGATE_PRIVATE_REQUIRED_FILES:-}" ]; then
      IFS=',' read -ra required_files <<<"${TRACEGATE_PRIVATE_REQUIRED_FILES}"
      for required_file in "${required_files[@]}"; do private_args+=(--required-file "${required_file}"); done
    fi
    (
      set -a
      # shellcheck disable=SC1090
      source "${RUNTIME_ENV}"
      set +a
      "${venv}/bin/tracegate-host-private-preflight" "${private_args[@]}"
    )
  fi
}

sync_release_files() {
  local runtime="$1" unit
  install -d -m 0755 "${SYSTEMD_DIR}" "${SYSCTL_DIR}" "${LOCAL_SBIN_DIR}"
  for unit in tracegate-host.service tracegate-shadowsocks2022.service; do
    "${SYSTEMCTL}" disable --now "${unit}" >/dev/null 2>&1 || true
    rm -f "${SYSTEMD_DIR}/${unit}"
  done
  for unit in "${runtime}"/deploy/systemd/*.service "${runtime}"/deploy/systemd/*.timer; do
    install -m 0644 "${unit}" "${SYSTEMD_DIR}/$(basename "${unit}")"
  done
  [ ! -f "${runtime}/deploy/systemd/tracegate-shadowtls-env" ] || \
    install -m 0755 "${runtime}/deploy/systemd/tracegate-shadowtls-env" "${LOCAL_SBIN_DIR}/tracegate-shadowtls-env"
  [ ! -f "${runtime}/deploy/systemd/tracegate-telemt-permissions" ] || \
    install -m 0755 "${runtime}/deploy/systemd/tracegate-telemt-permissions" "${LOCAL_SBIN_DIR}/tracegate-telemt-permissions"
  [ ! -f "${runtime}/deploy/host/tracegate-db-backup" ] || \
    install -m 0755 "${runtime}/deploy/host/tracegate-db-backup" "${LOCAL_SBIN_DIR}/tracegate-db-backup"
  if [ -f "${runtime}/deploy/host/90-tracegate-quic.conf" ]; then
    install -m 0644 "${runtime}/deploy/host/90-tracegate-quic.conf" "${SYSCTL_DIR}/90-tracegate-quic.conf"
    "${SYSCTL}" -p "${SYSCTL_DIR}/90-tracegate-quic.conf"
  fi
  if [ -f "${ETC_DIR}/tracegate.env" ]; then "${LOCAL_SBIN_DIR}/tracegate-shadowtls-env"; fi
  "${SYSTEMCTL}" daemon-reload
}

atomic_link() {
  local target="$1" link="$2" temporary
  temporary="${link}.new.$$"
  rm -f "${temporary}"
  ln -s "${target}" "${temporary}"
  "${PYTHON}" -c 'import os,sys; os.replace(sys.argv[1], sys.argv[2])' "${temporary}" "${link}"
}

capture_previous_state() {
  local file="${STATE_DIR}/previous.env"
  install -d -m 0700 "${STATE_DIR}"
  [ -L "${INSTALL_ROOT}/current" ] || die "${INSTALL_ROOT}/current is not a symlink"
  [ -L "${INSTALL_ROOT}/app" ] || die "${INSTALL_ROOT}/app is not a symlink"
  [ -L "${INSTALL_ROOT}/venv" ] || die "${INSTALL_ROOT}/venv is not a symlink"
  {
    printf 'PREVIOUS_CURRENT=%q\n' "$(readlink -f "${INSTALL_ROOT}/current")"
    printf 'PREVIOUS_APP=%q\n' "$(readlink -f "${INSTALL_ROOT}/app")"
    printf 'PREVIOUS_VENV=%q\n' "$(readlink -f "${INSTALL_ROOT}/venv")"
  } >"${file}.tmp"
  chmod 0600 "${file}.tmp"
  mv -f "${file}.tmp" "${file}"
}

switch_release() {
  local release="$1"
  atomic_link "${release}/runtime" "${INSTALL_ROOT}/current"
  atomic_link "${release}/runtime" "${INSTALL_ROOT}/app"
  atomic_link "${release}/venv" "${INSTALL_ROOT}/venv"
}

restart_role() {
  local unit
  for unit in "${ROLE_UNITS[@]}"; do "${SYSTEMCTL}" enable "${unit}" >/dev/null || return 1; done
  for unit in "${ROLE_UNITS[@]}"; do "${SYSTEMCTL}" restart "${unit}" || return 1; done
}

wait_healthy() {
  local url healthy
  for _ in $(seq 1 "${HEALTH_ATTEMPTS}"); do
    healthy=1
    for url in "${HEALTH_URLS[@]}"; do
      "${CURL}" --fail --silent --show-error --max-time 5 "${url}" >/dev/null || healthy=0
    done
    [ "${healthy}" -eq 1 ] && return 0
    sleep "${HEALTH_DELAY_SECONDS}"
  done
  return 1
}

restore_previous() {
  local state="${STATE_DIR}/previous.env" previous_runtime
  [ -f "${state}" ] || die "no previous deployment state"
  # shellcheck disable=SC1090
  source "${state}"
  for path in "${PREVIOUS_CURRENT:-}" "${PREVIOUS_APP:-}" "${PREVIOUS_VENV:-}"; do [ -e "${path}" ] || die "previous release path is missing: ${path}"; done
  previous_runtime="${PREVIOUS_CURRENT}"
  sync_release_files "${previous_runtime}"
  atomic_link "${PREVIOUS_CURRENT}" "${INSTALL_ROOT}/current"
  atomic_link "${PREVIOUS_APP}" "${INSTALL_ROOT}/app"
  atomic_link "${PREVIOUS_VENV}" "${INSTALL_ROOT}/venv"
  restart_role
}

preflight() {
  local version="$1"
  load_deploy_env
  need "${SYSTEMCTL}"; need "${CURL}"; need "${SYSCTL}"; need "${PYTHON}"; need stat
  validate_release "${version}"
  echo "native host preflight passed for ${TRACEGATE_HOST_ROLE} release ${version}"
}

deploy() {
  local version="$1" release
  preflight "${version}"
  release="$(release_path "${version}")"
  if [ "${TRACEGATE_HOST_ROLE}" = endpoint ]; then
    [ -n "${TRACEGATE_BACKUP_COMMAND:-}" ] || die "TRACEGATE_BACKUP_COMMAND is required on Endpoint"
    bash -lc "${TRACEGATE_BACKUP_COMMAND}"
    (
      cd "${release}/runtime"
      set -a
      # shellcheck disable=SC1090
      source "${RUNTIME_ENV}"
      set +a
      "${release}/venv/bin/tracegate-migrate-db"
    )
  fi
  capture_previous_state
  sync_release_files "${release}/runtime"
  switch_release "${release}"
  if ! restart_role || ! wait_healthy; then
    echo "new native runtime failed; restoring previous release" >&2
    restore_previous
    wait_healthy || die "rollback runtime failed readiness"
    return 1
  fi
  printf '%s\n' "${version}" >"${STATE_DIR}/active-version"
  chmod 0600 "${STATE_DIR}/active-version"
  echo "native host release ${version} is healthy"
}

rollback() {
  load_deploy_env
  restore_previous
  wait_healthy || die "rollback runtime failed readiness"
  echo "native host rollback completed; database migrations were not downgraded"
}

status() {
  load_deploy_env
  printf 'role=%s\ncurrent=%s\napp=%s\nvenv=%s\n' \
    "${TRACEGATE_HOST_ROLE}" \
    "$(readlink -f "${INSTALL_ROOT}/current" 2>/dev/null || true)" \
    "$(readlink -f "${INSTALL_ROOT}/app" 2>/dev/null || true)" \
    "$(readlink -f "${INSTALL_ROOT}/venv" 2>/dev/null || true)"
  "${SYSTEMCTL}" --no-pager --full status "${ROLE_UNITS[@]}" || true
}

action="${1:-}"
version="${2:-${TRACEGATE_TARGET_VERSION:-}}"
case "${action}" in
  preflight|deploy) [ -n "${version}" ] || die "usage: $0 ${action} VERSION"; "${action}" "${version}" ;;
  rollback|status) "${action}" ;;
  *) die "usage: $0 preflight VERSION | deploy VERSION | rollback | status" ;;
esac
