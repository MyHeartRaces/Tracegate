#!/usr/bin/env bash
set -euo pipefail

SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
VERSION="${1:-}"
INSTALL_ROOT="${TRACEGATE_INSTALL_ROOT:-/opt/tracegate}"
SYSTEMD_DIR="${TRACEGATE_SYSTEMD_DIR:-/etc/systemd/system}"
SYSCTL_DIR="${TRACEGATE_SYSCTL_DIR:-/etc/sysctl.d}"
LOCAL_SBIN_DIR="${TRACEGATE_LOCAL_SBIN_DIR:-/usr/local/sbin}"
LETSENCRYPT_DEPLOY_HOOK_DIR="${TRACEGATE_LETSENCRYPT_DEPLOY_HOOK_DIR:-/etc/letsencrypt/renewal-hooks/deploy}"
PYTHON="${TRACEGATE_PYTHON:-python3}"
SYSTEMCTL="${TRACEGATE_SYSTEMCTL:-systemctl}"
SYSCTL="${TRACEGATE_SYSCTL:-sysctl}"

die() { echo "tracegate host install: $*" >&2; exit 2; }
[ "$(id -u)" -eq 0 ] || die "run as root"
[[ "${VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.]+)?$ ]] || die "usage: $0 VERSION"
command -v "${PYTHON}" >/dev/null || die "missing ${PYTHON}"

"${PYTHON}" "${SOURCE_ROOT}/scripts/check_host_runtime.py" --root "${SOURCE_ROOT}"
"${PYTHON}" "${SOURCE_ROOT}/scripts/check_host_deploy.py" --root "${SOURCE_ROOT}"

wheel="$(find "${SOURCE_ROOT}/packages" -maxdepth 1 -type f -name "tracegate-${VERSION}-*.whl" -print -quit 2>/dev/null || true)"
[ -n "${wheel}" ] || die "missing bundled wheel packages/tracegate-${VERSION}-*.whl"

release_root="${INSTALL_ROOT}/releases/${VERSION}"
runtime="${release_root}/runtime"
venv="${release_root}/venv"
[ ! -e "${runtime}" ] && [ ! -e "${venv}" ] || die "release already staged: ${release_root}"

temporary="${INSTALL_ROOT}/releases/.${VERSION}.install.$$"
cleanup() { rm -rf "${temporary}" "${release_root}"; }
trap cleanup EXIT
install -d -m 0755 "${temporary}/runtime" "${temporary}/runtime/packages"
cp -a "${SOURCE_ROOT}/bundles" "${SOURCE_ROOT}/deploy" "${SOURCE_ROOT}/scripts" "${temporary}/runtime/"
cp -a "${SOURCE_ROOT}/pyproject.toml" "${SOURCE_ROOT}/requirements.lock" "${temporary}/runtime/"
cp -a "${wheel}" "${temporary}/runtime/packages/"
[ -f "${SOURCE_ROOT}/BUILD-INFO" ] && cp -a "${SOURCE_ROOT}/BUILD-INFO" "${temporary}/runtime/BUILD-INFO"

install -d -m 0755 "${INSTALL_ROOT}/releases" "${release_root}"
mv "${temporary}/runtime" "${runtime}"
rm -rf "${temporary}"

"${PYTHON}" -m venv "${venv}"
"${venv}/bin/python" -m pip install --disable-pip-version-check --no-input --upgrade pip
"${venv}/bin/python" -m pip install --disable-pip-version-check --no-input \
  -c "${runtime}/requirements.lock" "${runtime}/packages/$(basename "${wheel}")"
for command in tracegate-api tracegate-agent tracegate-backhaul-fronts tracegate-bot tracegate-dispatcher tracegate-migrate-db tracegate-host-private-preflight; do
  [ -x "${venv}/bin/${command}" ] || die "wheel did not install ${command}"
done
trap - EXIT

install -d -m 0755 "${SYSTEMD_DIR}" "${SYSCTL_DIR}" "${LOCAL_SBIN_DIR}" "${LETSENCRYPT_DEPLOY_HOOK_DIR}"
for retired_unit in tracegate-host.service tracegate-shadowsocks2022.service; do
  "${SYSTEMCTL}" disable --now "${retired_unit}" >/dev/null 2>&1 || true
  rm -f "${SYSTEMD_DIR}/${retired_unit}"
done
for unit in "${runtime}"/deploy/systemd/*.service "${runtime}"/deploy/systemd/*.timer; do
  install -m 0644 "${unit}" "${SYSTEMD_DIR}/$(basename "${unit}")"
done
install -m 0755 "${runtime}/deploy/systemd/tracegate-shadowtls-env" "${LOCAL_SBIN_DIR}/tracegate-shadowtls-env"
install -m 0755 "${runtime}/deploy/systemd/tracegate-telemt-permissions" "${LOCAL_SBIN_DIR}/tracegate-telemt-permissions"
install -m 0755 "${runtime}/deploy/host/tracegate-db-backup" "${LOCAL_SBIN_DIR}/tracegate-db-backup"
install -m 0755 "${runtime}/deploy/host/tracegate-certbot-deploy-hook" \
  "${LETSENCRYPT_DEPLOY_HOOK_DIR}/reload-tracegate-tls.sh"
install -m 0644 "${runtime}/deploy/host/90-tracegate-quic.conf" "${SYSCTL_DIR}/90-tracegate-quic.conf"
"${SYSCTL}" -p "${SYSCTL_DIR}/90-tracegate-quic.conf"
"${SYSTEMCTL}" daemon-reload

echo "staged Tracegate host release ${VERSION} under ${release_root}"
echo "activate with ${runtime}/deploy/host/tracegate-host-deploy deploy ${VERSION}"
