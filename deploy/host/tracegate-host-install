#!/usr/bin/env bash
set -euo pipefail

SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
VERSION="${1:-}"
INSTALL_ROOT="${TRACEGATE_INSTALL_ROOT:-/opt/tracegate}"
SYSTEMD_DIR="${TRACEGATE_SYSTEMD_DIR:-/etc/systemd/system}"
SYSCTL_DIR="${TRACEGATE_SYSCTL_DIR:-/etc/sysctl.d}"
SYSCTL_BIN="${TRACEGATE_SYSCTL_BIN:-/sbin/sysctl}"

[ "$(id -u)" -eq 0 ] || { echo "tracegate host install: run as root" >&2; exit 2; }
[[ "${VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.]+)?$ ]] || {
  echo "usage: $0 VERSION" >&2
  exit 2
}
python3 "${SOURCE_ROOT}/scripts/check_host_runtime.py" --root "${SOURCE_ROOT}"
python3 "${SOURCE_ROOT}/scripts/check_host_deploy.py" --root "${SOURCE_ROOT}"

release_root="${INSTALL_ROOT}/releases/${VERSION}"
target="${release_root}/runtime"
[ ! -e "${target}" ] || { echo "release already installed: ${target}" >&2; exit 2; }
install -d -m 0755 "${release_root}"
mkdir "${target}"
cp -a "${SOURCE_ROOT}/bundles" "${SOURCE_ROOT}/deploy" "${SOURCE_ROOT}/scripts" "${target}/"
chmod 0755 "${target}/deploy/host/tracegate-host-deploy" "${target}/deploy/host/tracegate-host-install"
chmod 0755 \
  "${target}/deploy/systemd/tracegate-shadowtls-env" \
  "${target}/deploy/systemd/tracegate-telemt-permissions"

# Preserve the QUIC socket-buffer tuning that was part of the retired k3s
# host bootstrap. Without it Linux falls back to ~208 KiB UDP receive buffers
# after a reboot, which can drop bursts and tear down otherwise healthy QUIC
# sessions. Apply it before any data-plane service can be restarted.
install -d -m 0755 "${SYSCTL_DIR}"
install -m 0644 \
  "${target}/deploy/host/90-tracegate-quic.conf" \
  "${SYSCTL_DIR}/90-tracegate-quic.conf"
"${SYSCTL_BIN}" -p "${SYSCTL_DIR}/90-tracegate-quic.conf"

ln -s "${target}" "${INSTALL_ROOT}/current.new"
mv -Tf "${INSTALL_ROOT}/current.new" "${INSTALL_ROOT}/current"

install -m 0644 "${target}/deploy/host/tracegate-host.service" "${SYSTEMD_DIR}/tracegate-host.service"
for unit in \
  tracegate-grafana.service \
  tracegate-haproxy@.service \
  tracegate-hysteria-salamander.service \
  tracegate-hysteria@.service \
  tracegate-mtproto@.service \
  tracegate-nginx@.service \
  tracegate-prometheus.service \
  tracegate-shadowtls.service \
  tracegate-wireguard-sync.service \
  tracegate-wireguard.service \
  tracegate-wstunnel-wireguard.service \
  tracegate-xray@.service \
  tracegate-xray-ss2022.service
do
  install -m 0644 "${target}/deploy/systemd/${unit}" "${SYSTEMD_DIR}/${unit}"
done

# The ShadowTLS service reads a root-only derived environment file. Generate it
# before systemd parses the unit so no secret has to be embedded in this public
# release or the unit file itself.
if [ -f /etc/tracegate/tracegate.env ]; then
  "${target}/deploy/systemd/tracegate-shadowtls-env"
fi
systemctl daemon-reload
echo "installed Tracegate host release ${VERSION}; run tracegate-host-deploy preflight before activation"
