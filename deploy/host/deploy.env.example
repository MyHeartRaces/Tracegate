# Native host runtime coordinates only. Credentials remain in the role-specific
# runtime environment and are never stored here.
TRACEGATE_HOST_ROLE=endpoint
TRACEGATE_RUNTIME_ENV=/etc/tracegate/tracegate.env
TRACEGATE_ENTRY_RUNTIME_ENV=/etc/tracegate/tracegate-entry.env
TRACEGATE_PRIVATE_ROOT=/var/lib/tracegate/private
TRACEGATE_PRIVATE_ROLE=TRANSIT
TRACEGATE_PRIVATE_REQUIRED_FILES=profiles/transit/desired-state.json
TRACEGATE_API_HEALTH_URL=http://127.0.0.1:18080/ready
TRACEGATE_AGENT_HEALTH_URL=http://127.0.0.1:8070/v1/health
# Enable only after the host RTC has been verified against a trusted clock.
# This is the supported fallback when the provider blocks outbound NTP/UDP 123.
TRACEGATE_ENABLE_RTC_CLOCK_SYNC=false
TRACEGATE_BACKUP_COMMAND=/usr/local/sbin/tracegate-db-backup
TRACEGATE_DB_NAME=tracegate
TRACEGATE_BACKUP_DIR=/var/backups/tracegate
TRACEGATE_BACKUP_RETENTION_DAYS=30
# Optional off-host copy command. The selected program receives the completed
# archive path in TRACEGATE_BACKUP_FILE.
TRACEGATE_BACKUP_MIRROR_COMMAND=
