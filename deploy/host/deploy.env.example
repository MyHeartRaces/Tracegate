# This file contains deployment coordinates only. Runtime credentials belong in
# /etc/tracegate/tracegate.env with mode 0600 and are never committed.
TRACEGATE_IMAGE=ghcr.io/myheartraces/tracegate:latest
POSTGRES_IMAGE=postgres:latest
TRACEGATE_ENV_FILE=/etc/tracegate/tracegate.env
TRACEGATE_PRIVATE_ROOT=/var/lib/tracegate/private
TRACEGATE_AGENT_DATA_ROOT=/var/lib/tracegate/agent
TRACEGATE_API_PORT=18080
TRACEGATE_AGENT_PORT=8070
TRACEGATE_COMPOSE_PROFILES=control
TRACEGATE_PRIVATE_ROLE=TRANSIT
TRACEGATE_PRIVATE_REQUIRED_FILES=profiles/transit/desired-state.json
TRACEGATE_BACKUP_COMMAND=/usr/local/sbin/tracegate-backup
