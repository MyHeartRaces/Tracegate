APP_ENV=prod
LOG_LEVEL=INFO

# Core secrets
DATABASE_URL=postgresql+asyncpg://tracegate:REPLACE_ME@127.0.0.1:5432/tracegate
API_INTERNAL_TOKEN=REPLACE_ME
AGENT_AUTH_TOKEN=REPLACE_ME
BOT_API_TOKEN=REPLACE_ME

# Public surfaces
PUBLIC_BASE_URL=https://panel.example.com
# Keep Tracegate API off :8080 on single-host systemd installs because Xray API
# commonly owns 127.0.0.1:8080 on Entry/Transit nodes.
API_HOST=127.0.0.1
API_PORT=18080
BOT_API_BASE_URL=http://127.0.0.1:18080

# Telegram bootstrap
SUPERADMIN_TELEGRAM_IDS=[123456789]
BOT_TOKEN=REPLACE_ME

# Runtime roots
BUNDLE_ROOT=/opt/tracegate/bundles
BUNDLE_MATERIALIZED_ROOT=/var/lib/tracegate/materialized-bundles
BUNDLE_PRIVATE_OVERLAY_ROOT=/etc/tracegate/private/overlays
TRACEGATE_PRIVATE_RENDER_HOOK=/etc/tracegate/private/render-hook.sh
# Shared decoy root for nginx and Xray-native Hysteria masquerade.
XRAY_CENTRIC_DECOY_DIR=/var/www/decoy
# Local certificate/key pair reused by xray-centric Hysteria inbounds on each host.
XRAY_CENTRIC_TLS_CERT_FILE=/etc/tracegate/tls/ws.crt
XRAY_CENTRIC_TLS_KEY_FILE=/etc/tracegate/tls/ws.key
# Optional private files for Xray-native Hysteria obfuscation.
# Keep the actual FinalMask/ECH payloads outside the public repo.
XRAY_HYSTERIA_FINALMASK_FILE=
XRAY_HYSTERIA_FINALMASK_ENTRY_FILE=
XRAY_HYSTERIA_FINALMASK_TRANSIT_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_ENTRY_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_TRANSIT_FILE=
# Keep the real /guide text outside Git.
BOT_GUIDE_PATH=/etc/tracegate/private/bot/guide.md
# BOT_GUIDE_MESSAGE=[TRACEGATE_BOT_GUIDE_PLACEHOLDER]
BOT_WELCOME_REQUIRED=true
BOT_WELCOME_VERSION=tracegate-2.1-client-safety-v1
# Keep the real welcome/warning text outside Git.
BOT_WELCOME_MESSAGE_FILE=/etc/tracegate/private/bot/welcome-message.md
# BOT_WELCOME_MESSAGE=[TRACEGATE_BOT_WELCOME_MESSAGE_PLACEHOLDER]

# Entry / Transit addressing
DEFAULT_ENTRY_HOST=entry.example.com
DEFAULT_TRANSIT_HOST=transit.example.com

# Shared client material
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
REALITY_PUBLIC_KEY_ENTRY=
REALITY_SHORT_ID_ENTRY=
REALITY_PUBLIC_KEY_TRANSIT=
REALITY_SHORT_ID_TRANSIT=
REALITY_PRIVATE_KEY_ENTRY=
REALITY_PRIVATE_KEY_TRANSIT=
REALITY_DEST=splitter.wb.ru:443
REALITY_DEST_ENTRY=
REALITY_DEST_TRANSIT=
REALITY_SERVER_NAME_ENTRY=
REALITY_SERVER_NAME_TRANSIT=
# Optional prod-style static REALITY topology. JSON array of:
# [{"id":"shared-a","port":2501,"dest":"splitter.wb.ru","snis":["splitter.wb.ru"]}]
# Keep this fixed so ordinary config issuance only changes users via Xray API.
REALITY_MULTI_INBOUND_GROUPS=
ENTRY_TLS_SERVER_NAME=
TRANSIT_TLS_SERVER_NAME=
HYSTERIA_BOOTSTRAP_PASSWORD=REPLACE_ME
HYSTERIA_ECH_CONFIG_LIST=
HYSTERIA_ECH_CONFIG_LIST_ENTRY=
HYSTERIA_ECH_CONFIG_LIST_TRANSIT=
HYSTERIA_ECH_FORCE_QUERY=
HYSTERIA_ECH_FORCE_QUERY_ENTRY=
HYSTERIA_ECH_FORCE_QUERY_TRANSIT=

# Agent API mTLS
AGENT_SERVER_CERT=
AGENT_SERVER_KEY=
AGENT_CA_CERT=
AGENT_RUNTIME_PROFILE=xray-centric

# Dispatcher / observability
DISPATCHER_POLL_SECONDS=3
DISPATCHER_BATCH_SIZE=50
DISPATCHER_LOCK_TTL_SECONDS=60
DISPATCHER_MAX_ATTEMPTS=25
DISPATCHER_CONCURRENCY=10
DISPATCHER_METRICS_ENABLED=true
DISPATCHER_METRICS_HOST=127.0.0.1
DISPATCHER_METRICS_PORT=9091
DISPATCHER_OPS_ALERTS_ENABLED=false

# Bot metrics
BOT_METRICS_ENABLED=true
BOT_METRICS_HOST=127.0.0.1
BOT_METRICS_PORT=9092

# Grafana integration (optional)
GRAFANA_ENABLED=false
GRAFANA_INTERNAL_URL=http://127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_COOKIE_SECRET=
GRAFANA_OTP_TTL_SECONDS=300
GRAFANA_SESSION_TTL_SECONDS=3600

# Optional VLESS WS+TLS transport kept as a compatibility surface.
VLESS_WS_PATH=/ws
VLESS_WS_TLS_PORT=443
