APP_ENV=prod
LOG_LEVEL=INFO

# Transit-only node replacement profile.
# Keep all host and rollout values in this one file and install it as /etc/tracegate/tracegate.env.

# Control-plane dispatch used by replace-transit-node.sh after the host is rebuilt.
# Keep the local default for single-host testbeds; override it when the control plane lives elsewhere.
API_INTERNAL_TOKEN=REPLACE_ME
TRACEGATE_REPLACE_API_URL=http://127.0.0.1:18080
TRACEGATE_REPLACE_REAPPLY_BASE=true
TRACEGATE_REPLACE_REISSUE_CURRENT_REVISIONS=true
TRACEGATE_REPLACE_VALIDATE_RUNTIME=true
TRACEGATE_REPLACE_RENDER_PRIVATE_OVERLAYS=false
TRACEGATE_REPLACE_ENABLE_RUNTIME=true

# Runtime installer toggles used by replace-transit-node.sh.
INSTALL_COMPONENTS=xray,mtproto
INSTALL_PROXY_STACK=true
XRAY_INSTALL_POLICY=if-missing
MTPROTO_INSTALL_POLICY=if-missing
MTPROTO_REFRESH_BOOTSTRAP=if-missing

# Runtime roots
BUNDLE_ROOT=/opt/tracegate/bundles
BUNDLE_MATERIALIZED_ROOT=/var/lib/tracegate/materialized-bundles
BUNDLE_PRIVATE_OVERLAY_ROOT=/etc/tracegate/private/overlays
TRACEGATE_PRIVATE_RENDER_HOOK=/etc/tracegate/private/render-hook.sh
XRAY_CENTRIC_DECOY_DIR=/var/www/decoy
XRAY_CENTRIC_TLS_CERT_FILE=/etc/tracegate/tls/ws.crt
XRAY_CENTRIC_TLS_KEY_FILE=/etc/tracegate/tls/ws.key

# Public surfaces
DEFAULT_TRANSIT_HOST=transit.example.com

# Entry placeholders are still required by the shared bundle renderer until Entry/V2/V4 rollout is finished.
DEFAULT_ENTRY_HOST=entry-placeholder.example.com
REALITY_PRIVATE_KEY_ENTRY=REPLACE_ENTRY_PLACEHOLDER_PRIVATE_KEY
REALITY_SHORT_ID_ENTRY=0000000000000000
REALITY_DEST_ENTRY=www.cloudflare.com:443
ENTRY_TLS_SERVER_NAME=entry-placeholder.example.com

# Transit REALITY / Hysteria material
REALITY_PUBLIC_KEY_TRANSIT=REPLACE_ME
REALITY_SHORT_ID_TRANSIT=REPLACE_ME
REALITY_PRIVATE_KEY_TRANSIT=REPLACE_ME
REALITY_DEST_TRANSIT=splitter.wb.ru:443
REALITY_SERVER_NAME_TRANSIT=splitter.wb.ru
TRANSIT_TLS_SERVER_NAME=transit.example.com
HYSTERIA_BOOTSTRAP_PASSWORD=REPLACE_ME

# Optional prod-style static REALITY topology.
# [{"id":"shared-a","port":2501,"dest":"splitter.wb.ru","snis":["splitter.wb.ru"]}]
REALITY_MULTI_INBOUND_GROUPS=

# Agent runtime
AGENT_RUNTIME_PROFILE=xray-centric
AGENT_AUTH_TOKEN=REPLACE_ME
AGENT_HOST=0.0.0.0
AGENT_PORT=8070
AGENT_DRY_RUN=false
AGENT_DATA_ROOT=/var/lib/tracegate/agent-transit
PRIVATE_OBFUSCATION_BACKEND=zapret2
PRIVATE_RUNTIME_ROOT=/var/lib/tracegate/private
PRIVATE_TRANSIT_INTERFACE=eth0
PRIVATE_ZAPRET_PROFILE_DIR=/etc/tracegate/private/zapret
PRIVATE_ZAPRET_POLICY_DIR=/etc/tracegate/private/zapret
PRIVATE_ZAPRET_STATE_DIR=/var/lib/tracegate/private/zapret
PRIVATE_ZAPRET_PROFILE_ENTRY=entry-lite.env
PRIVATE_ZAPRET_PROFILE_TRANSIT=transit-lite.env
PRIVATE_ZAPRET_PROFILE_INTERCONNECT=entry-transit-stealth.env
PRIVATE_ZAPRET_PROFILE_MTPROTO=mtproto-extra.env
AGENT_STATS_URL=http://127.0.0.1:9999/traffic
AGENT_STATS_SECRET=REPLACE_ME
AGENT_XRAY_API_ENABLED=true
AGENT_XRAY_API_SERVER=127.0.0.1:8080
AGENT_XRAY_API_TIMEOUT_SECONDS=3

# Local runtime reload hooks
AGENT_RELOAD_XRAY_CMD=systemctl restart tracegate-xray@transit
AGENT_RELOAD_HAPROXY_CMD=systemctl restart tracegate-haproxy@transit
AGENT_RELOAD_NGINX_CMD=systemctl reload tracegate-nginx@transit || systemctl restart tracegate-nginx@transit
AGENT_RELOAD_OBFUSCATION_CMD=systemctl reload tracegate-obfuscation@transit || systemctl restart tracegate-obfuscation@transit
AGENT_RELOAD_FRONTING_CMD=systemctl reload tracegate-fronting@transit || systemctl restart tracegate-fronting@transit
AGENT_RELOAD_MTPROTO_CMD=systemctl reload tracegate-mtproto@transit || systemctl restart tracegate-mtproto@transit
AGENT_RELOAD_PROFILES_CMD=systemctl reload tracegate-profiles@transit || systemctl restart tracegate-profiles@transit
AGENT_RELOAD_LINK_CRYPTO_CMD=systemctl reload tracegate-link-crypto@transit || systemctl restart tracegate-link-crypto@transit

# Private profile/link-crypto handoff. Helpers are safe no-ops until their private env files enable them.
PRIVATE_MIERU_PROFILE_DIR=/etc/tracegate/private/mieru
PRIVATE_MIERU_SERVER_PROFILE=server.json
PRIVATE_LINK_CRYPTO_ENABLED=true
PRIVATE_LINK_CRYPTO_GENERATION=1
PRIVATE_LINK_CRYPTO_BIND_HOST=127.0.0.1
PRIVATE_LINK_CRYPTO_TRANSIT_PORT=10882
PRIVATE_LINK_CRYPTO_REMOTE_PORT=443
PRIVATE_LINK_CRYPTO_ROUTER_TRANSIT_ENABLED=false
PRIVATE_LINK_CRYPTO_ZAPRET2_ENABLED=false

# Transit private TCP/443 fanout / MTProto handoff.
PRIVATE_FRONTING_LISTEN_ADDR=127.0.0.1:10443
PRIVATE_FRONTING_REALITY_UPSTREAM=127.0.0.1:2443
PRIVATE_FRONTING_WS_TLS_UPSTREAM=127.0.0.1:4443
PRIVATE_FRONTING_MTPROTO_UPSTREAM=127.0.0.1:9443
PRIVATE_FRONTING_WS_SNI=transit.example.com
PRIVATE_FRONTING_MTPROTO_DOMAIN_OVERRIDE=
PRIVATE_MTPROTO_BACKEND=private
PRIVATE_MTPROTO_UPSTREAM_HOST=127.0.0.1
PRIVATE_MTPROTO_UPSTREAM_PORT=9443
PRIVATE_MTPROTO_SECRET_FILE=/etc/tracegate/private/mtproto/secret.txt

# Transit MTProto / decoy handoff
MTPROTO_DOMAIN=mtproto.example.com
MTPROTO_PUBLIC_PORT=443
MTPROTO_FRONTING_MODE=dedicated-dns-only
MTPROTO_HAPROXY_UPSTREAM=127.0.0.1:9443
MTPROTO_PUBLIC_PROFILE_FILE=/var/lib/tracegate/private/mtproto/public-profile.json
MTPROTO_ISSUED_STATE_FILE=/var/lib/tracegate/private/mtproto/issued.json
TRANSIT_DECOY_AUTH_LOGIN=
TRANSIT_DECOY_AUTH_PASSWORD=
TRANSIT_DECOY_SECRET_PATH=/vault/mtproto/
TRANSIT_DECOY_GITHUB_REPO_URL=https://github.com/MyHeartRaces/Tracegate
FRONTING_TOUCH_UDP_443=false
