#!/usr/bin/env bash
set -euo pipefail

# Renders the Endpoint-side ShadowTLS v3 backhaul server environment. This
# server terminates the source-gated backhaul port and forwards the decapsulated
# stream to the isolated SS2022 backhaul inbound (127.0.0.1:18444). The public
# port must be restricted to the Entry source address by host nftables.

runtime_env="${TRACEGATE_ENV_FILE:-/etc/tracegate/tracegate.env}"
target_env="${TRACEGATE_SHADOWTLS_BACKHAUL_ENV_FILE:-/etc/tracegate/private/shadowtls/backhaul.env}"

test -f "${runtime_env}" || {
  echo "tracegate shadowtls backhaul env: missing ${runtime_env}" >&2
  exit 1
}

set -a
# shellcheck disable=SC1090
source "${runtime_env}"
set +a

listen="${SHADOWTLS_BACKHAUL_LISTEN:-0.0.0.0:9443}"
tls_target="${SHADOWTLS_BACKHAUL_TLS_TARGET:-${SHADOWTLS_BACKHAUL_SNI:-${SHADOWTLS_BACKHAUL_SERVER_NAME:-}}}"
password="${SHADOWTLS_BACKHAUL_PASSWORD:-}"
if [[ "${listen}" != *:* ]]; then
  listen="0.0.0.0:${listen}"
fi
if [[ "${tls_target}" != *:* ]]; then
  tls_target="${tls_target}:443"
fi
test -n "${tls_target%%:*}" || {
  echo "tracegate shadowtls backhaul env: TLS target is missing" >&2
  exit 1
}
test -n "${password}" || {
  echo "tracegate shadowtls backhaul env: password is missing" >&2
  exit 1
}

install -d -m 0700 "$(dirname -- "${target_env}")"
tmp="${target_env}.tmp"
umask 077
printf 'SHADOWTLS_BACKHAUL_LISTEN=%q\nSHADOWTLS_BACKHAUL_TLS_TARGET=%q\nSHADOWTLS_BACKHAUL_PASSWORD=%q\n' \
  "${listen}" "${tls_target}" "${password}" >"${tmp}"
chmod 0600 "${tmp}"
mv -f "${tmp}" "${target_env}"
