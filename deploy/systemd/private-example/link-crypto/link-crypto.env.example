# Private Mieru link-crypto contract for Entry/Transit.
TRACEGATE_LINK_CRYPTO_ENABLED=false
TRACEGATE_LINK_CRYPTO_BACKEND=mieru
TRACEGATE_PRIVATE_RUNTIME_DIR=/var/lib/tracegate/private
TRACEGATE_LINK_CRYPTO_STATE_JSON=/var/lib/tracegate/private/link-crypto/transit/desired-state.json
TRACEGATE_LINK_CRYPTO_STATE_DIR=/var/lib/tracegate/private/link-crypto/runtime
TRACEGATE_LINK_CRYPTO_RUNTIME_DIR=/var/lib/tracegate/private/link-crypto/runtime
TRACEGATE_LINK_CRYPTO_RUNNER=/opt/link-crypto-private/tracegate-link-crypto
TRACEGATE_LINK_CRYPTO_UDP_RUNNER=tracegate-link-crypto-runner
TRACEGATE_MIERU_BIN=/usr/local/bin/mieru
TRACEGATE_HYSTERIA_BIN=/usr/local/bin/hysteria
TRACEGATE_LINK_CRYPTO_PAIRED_OBFS_RUNNER=tracegate-paired-udp-obfs-runner
TRACEGATE_LINK_CRYPTO_LOG_FILE=/var/lib/tracegate/private/link-crypto/runtime/mieru.log
TRACEGATE_LINK_CRYPTO_UDP_PLAN_FILE=/var/lib/tracegate/private/link-crypto/runtime/transit-udp-runner-plan.json
TRACEGATE_LINK_CRYPTO_NO_HOST_WIDE_INTERCEPTION=true
TRACEGATE_LINK_CRYPTO_NO_NFQUEUE=true
TRACEGATE_LINK_CRYPTO_RESTART_EXISTING=false
TRACEGATE_LINK_CRYPTO_OUTER_WSS_SPKI_PINNING_REQUIRED=true
TRACEGATE_LINK_CRYPTO_OUTER_WSS_ADMISSION_REQUIRED=true
TRACEGATE_LINK_CRYPTO_TCP_DPI_RESISTANCE_REQUIRED=true
TRACEGATE_LINK_CRYPTO_TCP_TRAFFIC_SHAPING_REQUIRED=true
TRACEGATE_LINK_CRYPTO_PROMOTION_PREFLIGHT_REQUIRED=true
TRACEGATE_LINK_CRYPTO_ZAPRET2_REQUIRED=true
TRACEGATE_LINK_CRYPTO_NOTES=Keep disabled until private Mieru and Hysteria2 UDP-link profiles exist. Reload starts missing processes only and never rewrites host-wide packet interception.
