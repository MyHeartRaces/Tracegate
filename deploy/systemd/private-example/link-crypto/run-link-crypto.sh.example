#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-start}"
ROLE="${2:-unknown}"
ROLE_LOWER="${ROLE,,}"

CONFIG_DIR="${CONFIG_DIR:-/etc/tracegate}"
TRACEGATE_PRIVATE_RUNTIME_DIR="${TRACEGATE_PRIVATE_RUNTIME_DIR:-/var/lib/tracegate/private}"
TRACEGATE_LINK_CRYPTO_ENABLED="${TRACEGATE_LINK_CRYPTO_ENABLED:-false}"
TRACEGATE_LINK_CRYPTO_BACKEND="${TRACEGATE_LINK_CRYPTO_BACKEND:-mieru}"
TRACEGATE_LINK_CRYPTO_STATE_JSON="${TRACEGATE_LINK_CRYPTO_STATE_JSON:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/link-crypto/${ROLE_LOWER}/desired-state.json}"
TRACEGATE_LINK_CRYPTO_STATE_DIR="${TRACEGATE_LINK_CRYPTO_STATE_DIR:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/link-crypto/runtime}"
TRACEGATE_LINK_CRYPTO_RUNTIME_DIR="${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR:-${TRACEGATE_LINK_CRYPTO_STATE_DIR}}"
TRACEGATE_LINK_CRYPTO_RUNNER="${TRACEGATE_LINK_CRYPTO_RUNNER:-/opt/link-crypto-private/tracegate-link-crypto}"
TRACEGATE_LINK_CRYPTO_UDP_RUNNER="${TRACEGATE_LINK_CRYPTO_UDP_RUNNER:-$(command -v tracegate-link-crypto-runner || true)}"
TRACEGATE_MIERU_BIN="${TRACEGATE_MIERU_BIN:-$(command -v mieru || true)}"
TRACEGATE_HYSTERIA_BIN="${TRACEGATE_HYSTERIA_BIN:-$(command -v hysteria || true)}"
TRACEGATE_LINK_CRYPTO_PAIRED_OBFS_RUNNER="${TRACEGATE_LINK_CRYPTO_PAIRED_OBFS_RUNNER:-$(command -v tracegate-paired-udp-obfs-runner || true)}"
TRACEGATE_LINK_CRYPTO_LOG_FILE="${TRACEGATE_LINK_CRYPTO_LOG_FILE:-${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}/mieru.log}"
TRACEGATE_LINK_CRYPTO_UDP_PLAN_FILE="${TRACEGATE_LINK_CRYPTO_UDP_PLAN_FILE:-${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}/${ROLE_LOWER}-udp-runner-plan.json}"
TRACEGATE_LINK_CRYPTO_NO_HOST_WIDE_INTERCEPTION="${TRACEGATE_LINK_CRYPTO_NO_HOST_WIDE_INTERCEPTION:-true}"
TRACEGATE_LINK_CRYPTO_NO_NFQUEUE="${TRACEGATE_LINK_CRYPTO_NO_NFQUEUE:-true}"
TRACEGATE_LINK_CRYPTO_RESTART_EXISTING="${TRACEGATE_LINK_CRYPTO_RESTART_EXISTING:-false}"
TRACEGATE_LINK_CRYPTO_OUTER_WSS_SPKI_PINNING_REQUIRED="${TRACEGATE_LINK_CRYPTO_OUTER_WSS_SPKI_PINNING_REQUIRED:-true}"
TRACEGATE_LINK_CRYPTO_OUTER_WSS_ADMISSION_REQUIRED="${TRACEGATE_LINK_CRYPTO_OUTER_WSS_ADMISSION_REQUIRED:-true}"
TRACEGATE_LINK_CRYPTO_TCP_DPI_RESISTANCE_REQUIRED="${TRACEGATE_LINK_CRYPTO_TCP_DPI_RESISTANCE_REQUIRED:-true}"
TRACEGATE_LINK_CRYPTO_TCP_TRAFFIC_SHAPING_REQUIRED="${TRACEGATE_LINK_CRYPTO_TCP_TRAFFIC_SHAPING_REQUIRED:-true}"
TRACEGATE_LINK_CRYPTO_PROMOTION_PREFLIGHT_REQUIRED="${TRACEGATE_LINK_CRYPTO_PROMOTION_PREFLIGHT_REQUIRED:-true}"
TRACEGATE_LINK_CRYPTO_ZAPRET2_REQUIRED="${TRACEGATE_LINK_CRYPTO_ZAPRET2_REQUIRED:-true}"

mkdir -p "${TRACEGATE_LINK_CRYPTO_STATE_DIR}" "${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}"

PROFILE_LIST_FILE="${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}/${ROLE_LOWER}-profiles.txt"
LAST_ACTION_FILE="${TRACEGATE_LINK_CRYPTO_STATE_DIR}/${ROLE_LOWER}-last-action.json"

is_true() {
  case "${1,,}" in
    1|true|yes|y|on) return 0 ;;
    *) return 1 ;;
  esac
}

slug_for_path() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

pid_file_for_profile() {
  local slug
  slug="$(slug_for_path "$1")"
  printf '%s/mieru-%s.pid' "${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}" "${slug}"
}

is_pid_running() {
  local pid_file="$1"
  [[ -f "${pid_file}" ]] || return 1
  local pid
  pid="$(cat "${pid_file}" 2>/dev/null || true)"
  [[ -n "${pid}" ]] || return 1
  kill -0 "${pid}" 2>/dev/null
}

stop_profile() {
  local profile="$1"
  local pid_file
  pid_file="$(pid_file_for_profile "${profile}")"
  if is_pid_running "${pid_file}"; then
    kill "$(cat "${pid_file}")"
    rm -f "${pid_file}"
    echo "tracegate link-crypto stopped profile=${profile}"
  fi
}

run_udp_link_runner() {
  [[ -s "${TRACEGATE_LINK_CRYPTO_STATE_JSON}" ]] || return 0
  local runner_action="${ACTION}"
  local runner_args=(
    "${runner_action}"
    --role "${ROLE}"
    --state-json "${TRACEGATE_LINK_CRYPTO_STATE_JSON}"
    --runtime-dir "${TRACEGATE_LINK_CRYPTO_RUNTIME_DIR}"
    --plan-file "${TRACEGATE_LINK_CRYPTO_UDP_PLAN_FILE}"
    --hysteria-bin "${TRACEGATE_HYSTERIA_BIN}"
    --paired-obfs-runner "${TRACEGATE_LINK_CRYPTO_PAIRED_OBFS_RUNNER}"
    --only-udp
  )
  if [[ -n "${TRACEGATE_LINK_CRYPTO_UDP_RUNNER}" ]]; then
    if [[ -x "${TRACEGATE_LINK_CRYPTO_UDP_RUNNER}" ]]; then
      "${TRACEGATE_LINK_CRYPTO_UDP_RUNNER}" "${runner_args[@]}"
      return
    fi
    local resolved_runner
    resolved_runner="$(command -v "${TRACEGATE_LINK_CRYPTO_UDP_RUNNER}" || true)"
    if [[ -n "${resolved_runner}" && -x "${resolved_runner}" ]]; then
      "${resolved_runner}" "${runner_args[@]}"
      return
    fi
  fi
  if command -v python3 >/dev/null 2>&1 && python3 -c 'import tracegate.cli.link_crypto_runner' >/dev/null 2>&1; then
    python3 -m tracegate.cli.link_crypto_runner "${runner_args[@]}"
    return
  fi
  echo "tracegate link-crypto udp runner not installed"
  return 1
}

validate_and_write_manifest() {
  python3 - "${ACTION}" "${ROLE}" "${TRACEGATE_LINK_CRYPTO_STATE_JSON}" "${PROFILE_LIST_FILE}" "${LAST_ACTION_FILE}" "${TRACEGATE_LINK_CRYPTO_BACKEND}" <<'PY'
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from ipaddress import ip_address
from pathlib import Path

action = sys.argv[1]
role = sys.argv[2].strip().upper()
state_path = Path(sys.argv[3])
profile_list_path = Path(sys.argv[4])
last_action_path = Path(sys.argv[5])
backend = sys.argv[6].strip().lower() or "mieru"

payload = {
    "timestamp": datetime.now(timezone.utc).isoformat(),
    "action": action,
    "role": role,
    "backend": backend,
    "desiredState": str(state_path),
    "statePresent": state_path.exists(),
    "secretMaterial": False,
    "profiles": [],
    "links": [],
}

if not state_path.exists():
    profile_list_path.parent.mkdir(parents=True, exist_ok=True)
    profile_list_path.write_text("", encoding="utf-8")
    last_action_path.parent.mkdir(parents=True, exist_ok=True)
    last_action_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    raise SystemExit(0)

state = json.loads(state_path.read_text(encoding="utf-8"))
if not isinstance(state, dict):
    raise SystemExit("tracegate link-crypto desired-state must be a JSON object")
if state.get("schema") != "tracegate.link-crypto.v1":
    raise SystemExit("tracegate link-crypto unsupported desired-state schema")
if str(state.get("role") or "").strip().upper() != role:
    raise SystemExit("tracegate link-crypto role mismatch")
if bool(state.get("secretMaterial", False)):
    raise SystemExit("tracegate link-crypto desired-state must not contain secrets")

transport_profiles = state.get("transportProfiles") if isinstance(state.get("transportProfiles"), dict) else {}
client_names = transport_profiles.get("clientNames") if isinstance(transport_profiles.get("clientNames"), list) else []
local_socks_policy = transport_profiles.get("localSocks") if isinstance(transport_profiles.get("localSocks"), dict) else {}
if not client_names:
    raise SystemExit("tracegate link-crypto transportProfiles.clientNames is missing")
if str(local_socks_policy.get("auth") or "").strip().lower() != "required":
    raise SystemExit("tracegate link-crypto transportProfiles local SOCKS5 auth must stay required")
if bool(local_socks_policy.get("allowAnonymousLocalhost", False)):
    raise SystemExit("tracegate link-crypto transportProfiles must not allow anonymous localhost SOCKS5")

known_variants: set[str] = set()
for profile_name in client_names:
    prefix = str(profile_name or "").strip().split("-", maxsplit=1)[0].upper()
    if len(prefix) > 1 and prefix.startswith("V") and prefix[1:].isdigit():
        known_variants.add(prefix)
required_profiles_by_class = {
    "entry-transit": {"V2", "V6"},
    "router-entry": {"V2", "V6"},
    "router-transit": {"V1", "V5", "V7"},
}

def parse_endpoint(raw: object, *, label: str) -> tuple[str, int]:
    value = str(raw or "").strip()
    host, sep, port_raw = value.rpartition(":")
    if not sep or not host or not port_raw:
        raise SystemExit(f"tracegate link-crypto {label} must be host:port")
    host = host.strip()
    if host.startswith("[") and host.endswith("]"):
        host = host[1:-1].strip()
    try:
        port = int(port_raw)
    except ValueError:
        raise SystemExit(f"tracegate link-crypto {label} port is invalid")
    if not host or port < 1 or port > 65535:
        raise SystemExit(f"tracegate link-crypto {label} must use a valid host:port")
    return host, port


def is_loopback_host(host: str) -> bool:
    if host.strip().lower() == "localhost":
        return True
    try:
        return ip_address(host).is_loopback
    except ValueError:
        return False


def require_private_file_ref(ref: object, *, label: str) -> str:
    if not isinstance(ref, dict):
        raise SystemExit(f"tracegate link-crypto {label} profileRef must be file")
    if str(ref.get("kind") or "").strip() != "file":
        raise SystemExit(f"tracegate link-crypto {label} profileRef must be file")
    path = str(ref.get("path") or "").strip()
    if not path:
        raise SystemExit(f"tracegate link-crypto {label} profileRef path is missing")
    if not bool(ref.get("secretMaterial", False)):
        raise SystemExit(f"tracegate link-crypto {label} profileRef must point to private material")
    return path

profiles: list[str] = []
links = state.get("links") if isinstance(state.get("links"), list) else []
for index, link in enumerate(links):
    if not isinstance(link, dict) or not bool(link.get("enabled", False)):
        continue
    link_class = str(link.get("class") or f"row-{index}").strip()
    if str(link.get("carrier") or "").strip().lower() != "mieru":
        raise SystemExit(f"tracegate link-crypto {link_class} carrier must be mieru")
    if str(link.get("managedBy") or "").strip() != "link-crypto":
        raise SystemExit(f"tracegate link-crypto {link_class} must be managed by link-crypto")
    if bool(link.get("xrayBackhaul", True)):
        raise SystemExit(f"tracegate link-crypto {link_class} must stay outside Xray backhaul")
    local = link.get("local") if isinstance(link.get("local"), dict) else {}
    local_host, _local_port = parse_endpoint(local.get("listen"), label=f"{link_class} local listen")
    if not is_loopback_host(local_host):
        raise SystemExit(f"tracegate link-crypto {link_class} local listen must stay loopback-bound")
    auth = local.get("auth") if isinstance(local.get("auth"), dict) else {}
    if not bool(auth.get("required", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} requires local auth")
    if str(auth.get("mode") or "").strip() != "private-profile":
        raise SystemExit(f"tracegate link-crypto {link_class} local auth mode must be private-profile")
    selected_profiles = link.get("selectedProfiles") if isinstance(link.get("selectedProfiles"), list) else []
    selected_set = {str(item or "").strip().upper() for item in selected_profiles if str(item or "").strip()}
    unknown_profiles = sorted(selected_set - known_variants)
    if unknown_profiles:
        raise SystemExit(
            f"tracegate link-crypto {link_class} selectedProfiles are not present in runtime-contract transportProfiles"
        )
    required_profiles = required_profiles_by_class.get(link_class, set())
    if required_profiles and selected_set != required_profiles:
        raise SystemExit(f"tracegate link-crypto {link_class} selectedProfiles must equal {sorted(required_profiles)}")
    profile_ref = link.get("profileRef") if isinstance(link.get("profileRef"), dict) else {}
    profile_path = require_private_file_ref(profile_ref, label=f"{link_class} Mieru")
    outer_carrier = link.get("outerCarrier") if isinstance(link.get("outerCarrier"), dict) else {}
    if link_class == "entry-transit":
        if not bool(outer_carrier.get("enabled", False)):
            raise SystemExit(f"tracegate link-crypto {link_class} outer WSS carrier must stay enabled")
        if str(outer_carrier.get("mode") or "").strip().lower() != "wss":
            raise SystemExit(f"tracegate link-crypto {link_class} outer carrier mode must stay wss")
        if not bool(outer_carrier.get("verifyTls", False)):
            raise SystemExit(f"tracegate link-crypto {link_class} outer carrier must verify TLS")
        tls_pinning = outer_carrier.get("tlsPinning") if isinstance(outer_carrier.get("tlsPinning"), dict) else {}
        if not bool(tls_pinning.get("required", False)):
            raise SystemExit(f"tracegate link-crypto {link_class} outer carrier must require SPKI pinning")
        if str(tls_pinning.get("mode") or "").strip() != "spki-sha256":
            raise SystemExit(f"tracegate link-crypto {link_class} SPKI pinning mode must stay spki-sha256")
        require_private_file_ref(tls_pinning.get("profileRef"), label=f"{link_class} SPKI")
        admission = outer_carrier.get("admission") if isinstance(outer_carrier.get("admission"), dict) else {}
        if not bool(admission.get("required", False)):
            raise SystemExit(f"tracegate link-crypto {link_class} outer carrier must require HMAC admission")
        if str(admission.get("mode") or "").strip() != "hmac-sha256-generation-bound":
            raise SystemExit(f"tracegate link-crypto {link_class} admission mode must stay hmac-sha256-generation-bound")
        if str(admission.get("header") or "").strip() != "Sec-WebSocket-Protocol":
            raise SystemExit(f"tracegate link-crypto {link_class} admission header must stay Sec-WebSocket-Protocol")
        if not bool(admission.get("rejectUnauthenticated", False)):
            raise SystemExit(f"tracegate link-crypto {link_class} must reject unauthenticated WSS admission")
        require_private_file_ref(admission.get("profileRef"), label=f"{link_class} admission")
    zapret2 = link.get("zapret2") if isinstance(link.get("zapret2"), dict) else {}
    if not bool(zapret2.get("required", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} zapret2 must be required")
    if not bool(zapret2.get("enabled", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} zapret2 must be enabled")
    if bool(zapret2.get("hostWideInterception", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} must not enable host-wide interception")
    if bool(zapret2.get("nfqueue", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} must not enable broad NFQUEUE")
    if str(zapret2.get("packetShaping") or "").strip() != "zapret2-scoped":
        raise SystemExit(f"tracegate link-crypto {link_class} zapret2 packetShaping must stay zapret2-scoped")
    if str(zapret2.get("applyMode") or "").strip() != "marked-flow-only":
        raise SystemExit(f"tracegate link-crypto {link_class} zapret2 applyMode must stay marked-flow-only")
    require_private_file_ref(zapret2.get("profileRef"), label=f"{link_class} zapret2")
    dpi = link.get("dpiResistance") if isinstance(link.get("dpiResistance"), dict) else {}
    if not bool(dpi.get("enabled", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} TCP DPI resistance must stay enabled")
    expected_dpi_mode = "mieru-wss-spki-hmac-zapret2-scoped" if link_class == "entry-transit" else "mieru-zapret2-scoped"
    if str(dpi.get("mode") or "").strip() != expected_dpi_mode:
        raise SystemExit(f"tracegate link-crypto {link_class} TCP DPI resistance mode must stay {expected_dpi_mode}")
    required_layers = {
        "mieru-private-auth",
        "scoped-zapret2",
        "private-zapret2-profile",
        "loopback-only",
        "generation-drain",
        "no-direct-backhaul",
    }
    if link_class == "entry-transit":
        required_layers.update({"outer-wss-tls", "spki-sha256-pin", "hmac-admission"})
    layers = {str(item or "").strip() for item in dpi.get("requiredLayers", []) if str(item or "").strip()}
    missing_layers = sorted(required_layers - layers)
    if missing_layers:
        raise SystemExit(f"tracegate link-crypto {link_class} TCP DPI resistance missing layers: {missing_layers}")
    dpi_zapret = dpi.get("zapret2") if isinstance(dpi.get("zapret2"), dict) else {}
    if not bool(dpi_zapret.get("required", False)) or not bool(dpi_zapret.get("enabled", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} DPI policy must require enabled zapret2")
    require_private_file_ref(dpi_zapret.get("profileRef"), label=f"{link_class} DPI zapret2")
    traffic_shaping = dpi.get("trafficShaping") if isinstance(dpi.get("trafficShaping"), dict) else {}
    if not bool(traffic_shaping.get("required", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} TCP traffic shaping must be required")
    if str(traffic_shaping.get("strategy") or "").strip() != "private-zapret2-profile":
        raise SystemExit(f"tracegate link-crypto {link_class} TCP traffic shaping strategy must stay private-zapret2-profile")
    if str(traffic_shaping.get("scope") or "").strip() != "marked-flow-only":
        raise SystemExit(f"tracegate link-crypto {link_class} TCP traffic shaping scope must stay marked-flow-only")
    require_private_file_ref(traffic_shaping.get("profileRef"), label=f"{link_class} TCP traffic shaping")
    promotion = dpi.get("promotionPreflight") if isinstance(dpi.get("promotionPreflight"), dict) else {}
    if not bool(promotion.get("required", False)) or not bool(promotion.get("failClosed", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} promotion preflight must be required and fail closed")
    required_checks = {"mieru-private-auth", "zapret2-scoped-profile", "no-direct-backhaul"}
    if link_class == "entry-transit":
        required_checks.update({"spki-pin", "hmac-admission"})
    checks = {str(item or "").strip() for item in promotion.get("checks", []) if str(item or "").strip()}
    missing_checks = sorted(required_checks - checks)
    if missing_checks:
        raise SystemExit(f"tracegate link-crypto {link_class} promotion preflight missing checks: {missing_checks}")
    require_private_file_ref(promotion.get("profileRef"), label=f"{link_class} promotion preflight")
    rotation = link.get("rotation") if isinstance(link.get("rotation"), dict) else {}
    if bool(rotation.get("restartExisting", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} must not restart existing generation")
    stability = link.get("stability") if isinstance(link.get("stability"), dict) else {}
    if bool(stability.get("dropUnrelatedTraffic", False)):
        raise SystemExit(f"tracegate link-crypto {link_class} must not drop unrelated traffic")
    profiles.append(profile_path)
    payload["links"].append(
        {
            "class": link_class,
            "side": str(link.get("side") or "").strip(),
            "localListen": str(local.get("listen") or "").strip(),
            "remoteEndpoint": str((link.get("remote") or {}).get("endpoint") if isinstance(link.get("remote"), dict) else "").strip(),
            "profileRef": profile_path,
        }
    )

unique_profiles = sorted(set(profiles))
payload["profiles"] = unique_profiles
payload["secretMaterial"] = bool(state.get("secretMaterial", False))
profile_list_path.parent.mkdir(parents=True, exist_ok=True)
profile_list_path.write_text("\n".join(unique_profiles) + ("\n" if unique_profiles else ""), encoding="utf-8")
last_action_path.parent.mkdir(parents=True, exist_ok=True)
last_action_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY
}

validate_and_write_manifest

if [[ "${ACTION}" == "stop" ]]; then
  run_udp_link_runner || true
  if [[ -f "${PROFILE_LIST_FILE}" ]]; then
    while IFS= read -r profile; do
      [[ -n "${profile}" ]] || continue
      stop_profile "${profile}"
    done < "${PROFILE_LIST_FILE}"
  fi
  echo "tracegate link-crypto stopped"
  exit 0
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_NO_HOST_WIDE_INTERCEPTION}"; then
  echo "tracegate link-crypto refuses host-wide interception"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_NO_NFQUEUE}"; then
  echo "tracegate link-crypto refuses broad NFQUEUE"
  exit 1
fi

if is_true "${TRACEGATE_LINK_CRYPTO_RESTART_EXISTING}"; then
  echo "tracegate link-crypto refuses restart-existing mode"
  exit 1
fi

if [[ "${TRACEGATE_LINK_CRYPTO_ENABLED,,}" != "true" ]]; then
  echo "tracegate link-crypto disabled"
  echo "action=${ACTION}"
  echo "role=${ROLE}"
  echo "desired_state=${TRACEGATE_LINK_CRYPTO_STATE_JSON}"
  exit 0
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_OUTER_WSS_SPKI_PINNING_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without outer WSS SPKI pinning"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_OUTER_WSS_ADMISSION_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without outer WSS HMAC admission"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_TCP_DPI_RESISTANCE_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without TCP DPI resistance"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_TCP_TRAFFIC_SHAPING_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without TCP traffic shaping"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_PROMOTION_PREFLIGHT_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without promotion preflight"
  exit 1
fi

if ! is_true "${TRACEGATE_LINK_CRYPTO_ZAPRET2_REQUIRED}"; then
  echo "tracegate link-crypto refuses to run without scoped zapret2"
  exit 1
fi

if [[ -x "${TRACEGATE_LINK_CRYPTO_RUNNER}" ]]; then
  TRACEGATE_LINK_CRYPTO_STATE_JSON="${TRACEGATE_LINK_CRYPTO_STATE_JSON}" \
  TRACEGATE_LINK_CRYPTO_PROFILE_LIST="${PROFILE_LIST_FILE}" \
  TRACEGATE_LINK_CRYPTO_LAST_ACTION="${LAST_ACTION_FILE}" \
  "${TRACEGATE_LINK_CRYPTO_RUNNER}" "${ACTION}" "${ROLE}" || true
fi

run_udp_link_runner

if [[ -z "${TRACEGATE_MIERU_BIN}" || ! -x "${TRACEGATE_MIERU_BIN}" ]]; then
  echo "tracegate link-crypto mieru binary not installed"
  exit 1
fi

if [[ ! -s "${PROFILE_LIST_FILE}" ]]; then
  echo "tracegate link-crypto has no enabled profiles"
  exit 0
fi

while IFS= read -r profile; do
  [[ -n "${profile}" ]] || continue
  if [[ ! -f "${profile}" ]]; then
    echo "tracegate link-crypto profile missing: ${profile}"
    exit 1
  fi
  pid_file="$(pid_file_for_profile "${profile}")"
  if is_pid_running "${pid_file}"; then
    echo "tracegate link-crypto already running profile=${profile}"
    continue
  fi
  nohup "${TRACEGATE_MIERU_BIN}" run -c "${profile}" >>"${TRACEGATE_LINK_CRYPTO_LOG_FILE}" 2>&1 &
  echo "$!" > "${pid_file}"
  echo "tracegate link-crypto started profile=${profile}"
done < "${PROFILE_LIST_FILE}"

echo "backend=${TRACEGATE_LINK_CRYPTO_BACKEND}"
echo "profile_list=${PROFILE_LIST_FILE}"
echo "last_action=${LAST_ACTION_FILE}"
