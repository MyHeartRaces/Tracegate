#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-start}"
ROLE="${2:-unknown}"
ROLE_LOWER="${ROLE,,}"

CONFIG_DIR="${CONFIG_DIR:-/etc/tracegate}"
TRACEGATE_PRIVATE_RUNTIME_DIR="${TRACEGATE_PRIVATE_RUNTIME_DIR:-/var/lib/tracegate/private}"
TRACEGATE_PROFILES_ENABLED="${TRACEGATE_PROFILES_ENABLED:-false}"
TRACEGATE_PROFILES_BACKEND="${TRACEGATE_PROFILES_BACKEND:-private}"
TRACEGATE_PROFILES_STATE_JSON="${TRACEGATE_PROFILES_STATE_JSON:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/profiles/${ROLE_LOWER}/desired-state.json}"
TRACEGATE_PROFILES_STATE_DIR="${TRACEGATE_PROFILES_STATE_DIR:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/profiles/runtime}"
TRACEGATE_PROFILES_RUNTIME_DIR="${TRACEGATE_PROFILES_RUNTIME_DIR:-${TRACEGATE_PROFILES_STATE_DIR}}"
TRACEGATE_PROFILES_RUNNER="${TRACEGATE_PROFILES_RUNNER:-/opt/profiles-private/tracegate-profiles}"
TRACEGATE_PROFILES_NO_ANONYMOUS_SOCKS="${TRACEGATE_PROFILES_NO_ANONYMOUS_SOCKS:-true}"
TRACEGATE_PROFILES_NO_HOST_WIDE_INTERCEPTION="${TRACEGATE_PROFILES_NO_HOST_WIDE_INTERCEPTION:-true}"
TRACEGATE_PROFILES_RESTART_EXISTING="${TRACEGATE_PROFILES_RESTART_EXISTING:-false}"

mkdir -p "${TRACEGATE_PROFILES_STATE_DIR}" "${TRACEGATE_PROFILES_RUNTIME_DIR}"

MANIFEST_FILE="${TRACEGATE_PROFILES_RUNTIME_DIR}/${ROLE_LOWER}-redacted-manifest.json"
LAST_ACTION_FILE="${TRACEGATE_PROFILES_STATE_DIR}/${ROLE_LOWER}-last-action.json"

is_true() {
  case "${1,,}" in
    1|true|yes|y|on) return 0 ;;
    *) return 1 ;;
  esac
}

validate_and_write_manifest() {
  python3 - "${ACTION}" "${ROLE}" "${TRACEGATE_PROFILES_STATE_JSON}" "${MANIFEST_FILE}" "${LAST_ACTION_FILE}" "${TRACEGATE_PROFILES_BACKEND}" <<'PY'
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

action = sys.argv[1]
role = sys.argv[2].strip().upper()
state_path = Path(sys.argv[3])
manifest_path = Path(sys.argv[4])
last_action_path = Path(sys.argv[5])
backend = sys.argv[6].strip().lower() or "private"

payload = {
    "timestamp": datetime.now(timezone.utc).isoformat(),
    "action": action,
    "role": role,
    "backend": backend,
    "desiredState": str(state_path),
    "statePresent": state_path.exists(),
    "secretMaterial": False,
    "counts": {
        "total": 0,
        "shadowsocks2022ShadowTLS": 0,
        "wireguardWSTunnel": 0,
    },
    "profiles": [],
}

if not state_path.exists():
    manifest_path.parent.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    last_action_path.parent.mkdir(parents=True, exist_ok=True)
    last_action_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    raise SystemExit(0)

state = json.loads(state_path.read_text(encoding="utf-8"))
if not isinstance(state, dict):
    raise SystemExit("tracegate profiles desired-state must be a JSON object")
if state.get("schema") != "tracegate.private-profiles.v1":
    raise SystemExit("tracegate profiles unsupported desired-state schema")
if str(state.get("role") or "").strip().upper() != role:
    raise SystemExit("tracegate profiles role mismatch")
if not bool(state.get("secretMaterial", False)):
    raise SystemExit("tracegate profiles desired-state must stay private and contain secret material")

transport_profiles = state.get("transportProfiles") if isinstance(state.get("transportProfiles"), dict) else {}
client_names = transport_profiles.get("clientNames") if isinstance(transport_profiles.get("clientNames"), list) else []
client_name_set = {str(name or "").strip() for name in client_names if str(name or "").strip()}
local_socks_policy = transport_profiles.get("localSocks") if isinstance(transport_profiles.get("localSocks"), dict) else {}
if not client_name_set:
    raise SystemExit("tracegate profiles transportProfiles.clientNames is missing")
if str(local_socks_policy.get("auth") or "").strip().lower() != "required":
    raise SystemExit("tracegate profiles transportProfiles local SOCKS5 auth must stay required")
if bool(local_socks_policy.get("allowAnonymousLocalhost", False)):
    raise SystemExit("tracegate profiles transportProfiles must not allow anonymous localhost SOCKS5")

counts = state.get("counts") if isinstance(state.get("counts"), dict) else {}
shadowtls_entries = state.get("shadowsocks2022ShadowTLS") if isinstance(state.get("shadowsocks2022ShadowTLS"), list) else []
wireguard_entries = state.get("wireguardWSTunnel") if isinstance(state.get("wireguardWSTunnel"), list) else []
payload["counts"] = {
    "total": len(shadowtls_entries) + len(wireguard_entries),
    "shadowsocks2022ShadowTLS": len(shadowtls_entries),
    "wireguardWSTunnel": len(wireguard_entries),
}
if int(counts.get("total") or 0) != payload["counts"]["total"]:
    raise SystemExit("tracegate profiles total count mismatch")

def require_local_socks(profile: dict, label: str) -> None:
    local_socks = profile.get("localSocks") if isinstance(profile.get("localSocks"), dict) else {}
    auth = local_socks.get("auth") if isinstance(local_socks.get("auth"), dict) else {}
    if not bool(local_socks.get("enabled", False)):
        raise SystemExit(f"tracegate profiles {label} local SOCKS must be enabled")
    if not bool(auth.get("required", False)):
        raise SystemExit(f"tracegate profiles {label} local SOCKS auth must be required")
    if str(auth.get("mode") or "").strip() != "username_password":
        raise SystemExit(f"tracegate profiles {label} local SOCKS auth must use username_password")
    if not str(auth.get("username") or "").strip() or not str(auth.get("password") or "").strip():
        raise SystemExit(f"tracegate profiles {label} local SOCKS credentials are missing")

def require_transport_profile(profile: dict, label: str) -> None:
    profile_name = str(profile.get("profile") or "").strip()
    if profile_name not in client_name_set:
        raise SystemExit(f"tracegate profiles {label} profile name is not present in transportProfiles.clientNames")

def require_obfuscation(profile: dict, label: str) -> None:
    obfuscation = profile.get("obfuscation") if isinstance(profile.get("obfuscation"), dict) else {}
    if bool(obfuscation.get("hostWideInterception", False)):
        raise SystemExit(f"tracegate profiles {label} must not enable host-wide interception")

def redacted_base(profile: dict, kind: str) -> dict:
    return {
        "kind": kind,
        "variant": str(profile.get("variant") or "").strip(),
        "profile": str(profile.get("profile") or "").strip(),
        "stage": str(profile.get("stage") or "").strip(),
        "connectionId": str(profile.get("connectionId") or "").strip(),
        "revisionId": str(profile.get("revisionId") or "").strip(),
        "server": str(profile.get("server") or "").strip(),
        "port": int(profile.get("port") or 0),
        "localSocksListen": str((profile.get("localSocks") or {}).get("listen") if isinstance(profile.get("localSocks"), dict) else "").strip(),
        "secretMaterial": "redacted",
    }

for index, profile in enumerate(shadowtls_entries):
    if not isinstance(profile, dict):
        continue
    variant = str(profile.get("variant") or "").strip().upper()
    label = f"shadowtls-{variant or index}"
    if role == "ENTRY" and variant != "V6":
        raise SystemExit("tracegate profiles Entry handoff must only contain V6 chain relays")
    if role == "TRANSIT" and variant not in {"V5", "V6"}:
        raise SystemExit("tracegate profiles Transit handoff only supports V5/V6 ShadowTLS entries")
    require_transport_profile(profile, label)
    require_local_socks(profile, label)
    require_obfuscation(profile, label)
    payload["profiles"].append(redacted_base(profile, "shadowsocks2022-shadowtls"))

for index, profile in enumerate(wireguard_entries):
    if not isinstance(profile, dict):
        continue
    label = f"wireguard-{str(profile.get('variant') or index).strip()}"
    if role != "TRANSIT":
        raise SystemExit("tracegate profiles Entry handoff must not contain V7 WireGuard/WSTunnel entries")
    require_transport_profile(profile, label)
    require_local_socks(profile, label)
    require_obfuscation(profile, label)
    payload["profiles"].append(redacted_base(profile, "wireguard-wstunnel"))

manifest_path.parent.mkdir(parents=True, exist_ok=True)
manifest_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
last_action_path.parent.mkdir(parents=True, exist_ok=True)
last_action_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY
}

validate_and_write_manifest

if [[ "${ACTION}" == "stop" ]]; then
  if [[ -x "${TRACEGATE_PROFILES_RUNNER}" ]]; then
    TRACEGATE_PROFILES_STATE_JSON="${TRACEGATE_PROFILES_STATE_JSON}" \
    TRACEGATE_PROFILES_MANIFEST="${MANIFEST_FILE}" \
    TRACEGATE_PROFILES_LAST_ACTION="${LAST_ACTION_FILE}" \
    "${TRACEGATE_PROFILES_RUNNER}" stop "${ROLE}" || true
  fi
  echo "tracegate profiles stopped"
  exit 0
fi

if ! is_true "${TRACEGATE_PROFILES_NO_ANONYMOUS_SOCKS}"; then
  echo "tracegate profiles refuses anonymous SOCKS mode"
  exit 1
fi

if ! is_true "${TRACEGATE_PROFILES_NO_HOST_WIDE_INTERCEPTION}"; then
  echo "tracegate profiles refuses host-wide interception"
  exit 1
fi

if is_true "${TRACEGATE_PROFILES_RESTART_EXISTING}"; then
  echo "tracegate profiles refuses restart-existing mode"
  exit 1
fi

if [[ "${TRACEGATE_PROFILES_ENABLED,,}" != "true" ]]; then
  echo "tracegate profiles disabled"
  echo "action=${ACTION}"
  echo "role=${ROLE}"
  echo "desired_state=${TRACEGATE_PROFILES_STATE_JSON}"
  echo "manifest=${MANIFEST_FILE}"
  exit 0
fi

if [[ ! -x "${TRACEGATE_PROFILES_RUNNER}" ]]; then
  echo "tracegate profiles private runner not installed: ${TRACEGATE_PROFILES_RUNNER}"
  exit 1
fi

TRACEGATE_PROFILES_STATE_JSON="${TRACEGATE_PROFILES_STATE_JSON}" \
TRACEGATE_PROFILES_MANIFEST="${MANIFEST_FILE}" \
TRACEGATE_PROFILES_LAST_ACTION="${LAST_ACTION_FILE}" \
TRACEGATE_PROFILES_RESTART_EXISTING="${TRACEGATE_PROFILES_RESTART_EXISTING}" \
"${TRACEGATE_PROFILES_RUNNER}" "${ACTION}" "${ROLE}"

echo "backend=${TRACEGATE_PROFILES_BACKEND}"
echo "manifest=${MANIFEST_FILE}"
echo "last_action=${LAST_ACTION_FILE}"
