# Private V5/V6/V7 profile adapter contract.
TRACEGATE_PROFILES_ENABLED=false
TRACEGATE_PROFILES_BACKEND=private
TRACEGATE_PRIVATE_RUNTIME_DIR=/var/lib/tracegate/private
TRACEGATE_PROFILES_STATE_JSON=/var/lib/tracegate/private/profiles/transit/desired-state.json
TRACEGATE_PROFILES_STATE_DIR=/var/lib/tracegate/private/profiles/runtime
TRACEGATE_PROFILES_RUNTIME_DIR=/var/lib/tracegate/private/profiles/runtime
TRACEGATE_PROFILES_RUNNER=/opt/profiles-private/tracegate-profiles
TRACEGATE_PROFILES_NO_ANONYMOUS_SOCKS=true
TRACEGATE_PROFILES_NO_HOST_WIDE_INTERCEPTION=true
TRACEGATE_PROFILES_RESTART_EXISTING=false
TRACEGATE_PROFILES_NOTES=Keep disabled until a private sing-box ShadowTLS WSTunnel WireGuard adapter exists. The public scaffold only validates and emits redacted manifests.
