# Toggle is host-local and intentionally not consumed by the public Python app.
TRACEGATE_OBFUSCATION_ENABLED=false

# Backend selector for the private wrapper. The public repo only defines the handoff surface.
TRACEGATE_OBFUSCATION_BACKEND=zapret2

# Shared runtime roots for host-local wrappers.
TRACEGATE_PRIVATE_RUNTIME_DIR=/var/lib/tracegate/private
TRACEGATE_ZAPRET_ROOT=/opt/zapret2-private
TRACEGATE_ZAPRET_RUNNER=/opt/zapret2-private/tracegate-zapret-wrapper
TRACEGATE_ZAPRET_POLICY_DIR=/etc/tracegate/private/zapret
TRACEGATE_ZAPRET_STATE_DIR=/var/lib/tracegate/private/zapret
TRACEGATE_ZAPRET_PROFILE_DIR=/etc/tracegate/private/zapret
TRACEGATE_ZAPRET_PROFILE_ENTRY=entry-lite.env
TRACEGATE_ZAPRET_PROFILE_TRANSIT=transit-lite.env
TRACEGATE_ZAPRET_PROFILE_INTERCONNECT=entry-transit-stealth.env
TRACEGATE_ZAPRET_PROFILE_MTPROTO=mtproto-extra.env
TRACEGATE_FINALMASK_MODE=overlay
TRACEGATE_ENTRY_RUNTIME_CONTRACT=/var/lib/tracegate/agent-entry/runtime/runtime-contract.json
TRACEGATE_TRANSIT_RUNTIME_CONTRACT=/var/lib/tracegate/agent-transit/runtime/runtime-contract.json

# Override network interfaces per host when needed.
TRACEGATE_ENTRY_INTERFACE=eth0
TRACEGATE_TRANSIT_INTERFACE=eth0
