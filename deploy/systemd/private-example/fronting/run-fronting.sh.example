#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-start}"
ROLE="${2:-unknown}"

CONFIG_DIR="${CONFIG_DIR:-/etc/tracegate}"
TRACEGATE_PRIVATE_RUNTIME_DIR="${TRACEGATE_PRIVATE_RUNTIME_DIR:-/var/lib/tracegate/private}"
TRACEGATE_FRONTING_ENABLED="${TRACEGATE_FRONTING_ENABLED:-false}"
TRACEGATE_FRONTING_BACKEND="${TRACEGATE_FRONTING_BACKEND:-private}"
TRACEGATE_FRONTING_RUNTIME_STATE_JSON="${TRACEGATE_FRONTING_RUNTIME_STATE_JSON:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/obfuscation/${ROLE}/runtime-state.json}"
TRACEGATE_FRONTING_LISTEN_ADDR="${TRACEGATE_FRONTING_LISTEN_ADDR:-127.0.0.1:10443}"
TRACEGATE_FRONTING_PROTOCOL="${TRACEGATE_FRONTING_PROTOCOL:-tcp}"
TRACEGATE_FRONTING_REALITY_UPSTREAM="${TRACEGATE_FRONTING_REALITY_UPSTREAM:-127.0.0.1:2443}"
TRACEGATE_FRONTING_WS_TLS_UPSTREAM="${TRACEGATE_FRONTING_WS_TLS_UPSTREAM:-127.0.0.1:4443}"
TRACEGATE_FRONTING_MTPROTO_UPSTREAM="${TRACEGATE_FRONTING_MTPROTO_UPSTREAM:-127.0.0.1:9443}"
TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE="${TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE:-${CONFIG_DIR}/private/zapret/mtproto-extra.env}"
TRACEGATE_FRONTING_STATE_DIR="${TRACEGATE_FRONTING_STATE_DIR:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/fronting}"
TRACEGATE_FRONTING_RUNTIME_DIR="${TRACEGATE_FRONTING_RUNTIME_DIR:-${TRACEGATE_FRONTING_STATE_DIR}/runtime}"
TRACEGATE_FRONTING_RUNNER="${TRACEGATE_FRONTING_RUNNER:-/opt/fronting-private/tracegate-fronting-gateway}"
TRACEGATE_FRONTING_HAPROXY_BIN="${TRACEGATE_FRONTING_HAPROXY_BIN:-/usr/sbin/haproxy}"
TRACEGATE_FRONTING_WS_SNI="${TRACEGATE_FRONTING_WS_SNI:-nlconn.tracegate.su}"
TRACEGATE_FRONTING_MTPROTO_DOMAIN_OVERRIDE="${TRACEGATE_FRONTING_MTPROTO_DOMAIN_OVERRIDE:-}"
TRACEGATE_FRONTING_TOUCH_UDP_443="${TRACEGATE_FRONTING_TOUCH_UDP_443:-false}"

mkdir -p "${TRACEGATE_FRONTING_STATE_DIR}" "${TRACEGATE_FRONTING_RUNTIME_DIR}"

TRACEGATE_FRONTING_CFG_FILE="${TRACEGATE_FRONTING_CFG_FILE:-${TRACEGATE_FRONTING_RUNTIME_DIR}/haproxy.cfg}"
TRACEGATE_FRONTING_PID_FILE="${TRACEGATE_FRONTING_PID_FILE:-${TRACEGATE_FRONTING_RUNTIME_DIR}/haproxy.pid}"

python3 - "${TRACEGATE_FRONTING_STATE_DIR}" "${ACTION}" "${ROLE}" "${TRACEGATE_FRONTING_RUNTIME_STATE_JSON}" "${TRACEGATE_FRONTING_LISTEN_ADDR}" "${TRACEGATE_FRONTING_PROTOCOL}" "${TRACEGATE_FRONTING_REALITY_UPSTREAM}" "${TRACEGATE_FRONTING_WS_TLS_UPSTREAM}" "${TRACEGATE_FRONTING_MTPROTO_UPSTREAM}" "${TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE}" "${TRACEGATE_FRONTING_TOUCH_UDP_443}" "${TRACEGATE_FRONTING_CFG_FILE}" "${TRACEGATE_FRONTING_PID_FILE}" "${TRACEGATE_FRONTING_WS_SNI}" "${TRACEGATE_FRONTING_MTPROTO_DOMAIN_OVERRIDE}" "${TRACEGATE_FRONTING_BACKEND}" <<'PY'
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

state_dir = Path(sys.argv[1])
runtime_state_path = Path(sys.argv[4])
cfg_path = Path(sys.argv[12])
mtproto_domain = ""
mtproto_fronting_mode = "dedicated-dns-only"
tcp_owner = ""
udp_owner = ""

if runtime_state_path.exists():
    try:
        runtime_state = json.loads(runtime_state_path.read_text(encoding="utf-8"))
    except Exception:
        runtime_state = {}
    if isinstance(runtime_state, dict):
        fronting = runtime_state.get("fronting")
        if isinstance(fronting, dict):
            mtproto_domain = str(fronting.get("mtprotoDomain") or "").strip()
            mtproto_fronting_mode = str(fronting.get("mtprotoFrontingMode") or mtproto_fronting_mode).strip().lower()
            tcp_owner = str(fronting.get("tcp443Owner") or "").strip()
            udp_owner = str(fronting.get("udp443Owner") or "").strip()

mtproto_domain_override = str(sys.argv[15]).strip()
if mtproto_domain_override:
    mtproto_domain = mtproto_domain_override

listen_addr = str(sys.argv[5]).strip()
ws_sni = str(sys.argv[14]).strip()
pid_file = str(sys.argv[13]).strip()

cfg_lines = [
    "global",
    "  log /dev/log local0",
    "  log /dev/log local1 notice",
    "  daemon",
    "  maxconn 20000",
    "",
    "defaults",
    "  log global",
    "  mode tcp",
    "  option tcplog",
    "  timeout connect 5s",
    "  timeout client 5m",
    "  timeout server 5m",
    "  timeout tunnel 1h",
    "",
    "frontend fe_tracegate_private_fronting",
    f"  bind {listen_addr}",
    "  tcp-request inspect-delay 5s",
    "  tcp-request content accept if { req.ssl_hello_type 1 }",
]
if mtproto_domain:
    cfg_lines.append(f"  acl mtproto_sni req.ssl_sni -i {mtproto_domain}")
if ws_sni:
    cfg_lines.append(f"  acl ws_tls_sni req.ssl_sni -i {ws_sni}")
if mtproto_domain:
    cfg_lines.append("  use_backend be_mtproto if mtproto_sni")
if ws_sni:
    cfg_lines.append("  use_backend be_ws_tls if ws_tls_sni")
cfg_lines.extend(
    [
        "  default_backend be_reality",
        "",
        "backend be_reality",
        f"  server reality {sys.argv[7]} check",
        "",
        "backend be_ws_tls",
        f"  server ws_tls {sys.argv[8]} check",
        "",
        "backend be_mtproto",
        f"  server mtproto {sys.argv[9]} check",
        "",
    ]
)
cfg_path.parent.mkdir(parents=True, exist_ok=True)
cfg_path.write_text("\n".join(cfg_lines), encoding="utf-8")

payload = {
    "timestamp": datetime.now(timezone.utc).isoformat(),
    "action": sys.argv[2],
    "role": sys.argv[3],
    "backend": str(sys.argv[16]).strip().lower(),
    "runtimeStateJson": str(runtime_state_path),
    "listenAddr": sys.argv[5],
    "protocol": sys.argv[6],
    "realityUpstream": sys.argv[7],
    "wsTlsUpstream": sys.argv[8],
    "mtprotoUpstream": sys.argv[9],
    "mtprotoProfileFile": sys.argv[10],
    "touchUdp443": str(sys.argv[11]).strip().lower() == "true",
    "mtprotoDomain": mtproto_domain,
    "mtprotoFrontingMode": mtproto_fronting_mode,
    "tcp443Owner": tcp_owner,
    "udp443Owner": udp_owner,
    "cfgFile": str(cfg_path),
    "pidFile": pid_file,
    "wsSni": ws_sni,
}
state_dir.mkdir(parents=True, exist_ok=True)
(state_dir / "last-action.json").write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY

is_running() {
  [[ -f "${TRACEGATE_FRONTING_PID_FILE}" ]] || return 1
  local pid
  pid="$(cat "${TRACEGATE_FRONTING_PID_FILE}" 2>/dev/null || true)"
  [[ -n "${pid}" ]] || return 1
  kill -0 "${pid}" 2>/dev/null
}

if [[ "${TRACEGATE_FRONTING_TOUCH_UDP_443,,}" == "true" ]]; then
  echo "tracegate fronting must not claim udp/443"
  exit 1
fi

if [[ "${ACTION}" == "stop" ]]; then
  if is_running; then
    kill "$(cat "${TRACEGATE_FRONTING_PID_FILE}")"
    rm -f "${TRACEGATE_FRONTING_PID_FILE}"
    echo "tracegate fronting stopped"
  else
    echo "tracegate fronting not running"
  fi
  exit 0
fi

if [[ "${TRACEGATE_FRONTING_ENABLED,,}" != "true" ]]; then
  echo "tracegate fronting disabled"
  echo "action=${ACTION}"
  echo "role=${ROLE}"
  echo "listen=${TRACEGATE_FRONTING_LISTEN_ADDR}"
  echo "protocol=${TRACEGATE_FRONTING_PROTOCOL}"
  exit 0
fi

if [[ ! -x "${TRACEGATE_FRONTING_HAPROXY_BIN}" ]]; then
  echo "tracegate fronting haproxy not installed: ${TRACEGATE_FRONTING_HAPROXY_BIN}"
  exit 1
fi

"${TRACEGATE_FRONTING_HAPROXY_BIN}" -c -f "${TRACEGATE_FRONTING_CFG_FILE}" >/dev/null

if [[ -x "${TRACEGATE_FRONTING_RUNNER}" ]]; then
  TRACEGATE_FRONTING_RUNTIME_STATE_JSON="${TRACEGATE_FRONTING_RUNTIME_STATE_JSON}" \
  TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE="${TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE}" \
  TRACEGATE_FRONTING_REALITY_UPSTREAM="${TRACEGATE_FRONTING_REALITY_UPSTREAM}" \
  TRACEGATE_FRONTING_WS_TLS_UPSTREAM="${TRACEGATE_FRONTING_WS_TLS_UPSTREAM}" \
  TRACEGATE_FRONTING_MTPROTO_UPSTREAM="${TRACEGATE_FRONTING_MTPROTO_UPSTREAM}" \
  "${TRACEGATE_FRONTING_RUNNER}" "${ACTION}" "${ROLE}" || true
fi

if is_running; then
  OLD_PID="$(cat "${TRACEGATE_FRONTING_PID_FILE}")"
  "${TRACEGATE_FRONTING_HAPROXY_BIN}" -D -f "${TRACEGATE_FRONTING_CFG_FILE}" -p "${TRACEGATE_FRONTING_PID_FILE}" -sf "${OLD_PID}"
  echo "tracegate fronting reloaded"
else
  "${TRACEGATE_FRONTING_HAPROXY_BIN}" -D -f "${TRACEGATE_FRONTING_CFG_FILE}" -p "${TRACEGATE_FRONTING_PID_FILE}"
  echo "tracegate fronting started"
fi

echo "backend=${TRACEGATE_FRONTING_BACKEND}"
echo "cfg_file=${TRACEGATE_FRONTING_CFG_FILE}"
echo "pid_file=${TRACEGATE_FRONTING_PID_FILE}"
