#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${CONFIG_DIR:-/etc/tracegate}"
BUNDLE_MATERIALIZED_ROOT="${BUNDLE_MATERIALIZED_ROOT:-/var/lib/tracegate/materialized-bundles}"
BUNDLE_PRIVATE_OVERLAY_ROOT="${BUNDLE_PRIVATE_OVERLAY_ROOT:-${CONFIG_DIR}/private/overlays}"

# This hook runs after the public renderer materializes Entry / Transit bundles.
# Keep private packet camouflage or host-local automation here instead of Git.
#
# Intended use cases:
# - install or refresh zapret2 assets from a private source
# - rewrite materialized configs with local-only transport masking
# - stage decoy content that must not live in the repository
# - call local systemctl reload/restart wrappers for extra services
# - chain with render-xray-centric-overlays.sh during the runtime refactor
#
# Deliberately no public algorithm is shipped here.

echo "tracegate private render hook placeholder"
echo "materialized bundles: ${BUNDLE_MATERIALIZED_ROOT}"
echo "private overlays: ${BUNDLE_PRIVATE_OVERLAY_ROOT}"
