# Host-local MTProto gateway contract.
TRACEGATE_MTPROTO_ENABLED=false
TRACEGATE_MTPROTO_ROLE=transit
TRACEGATE_MTPROTO_BACKEND=private
TRACEGATE_PRIVATE_RUNTIME_DIR=/var/lib/tracegate/private
TRACEGATE_MTPROTO_RUNTIME_STATE_JSON=/var/lib/tracegate/private/obfuscation/transit/runtime-state.json
TRACEGATE_MTPROTO_PROFILE_FILE=/etc/tracegate/private/zapret/mtproto-extra.env
TRACEGATE_MTPROTO_DOMAIN=proxied.tracegate.su
# Use a real dedicated hostname for MTProto fake-TLS masking.
# Keep it DNS-only unless you have a true L4 proxy in front of it.
TRACEGATE_MTPROTO_PUBLIC_PORT=443
TRACEGATE_MTPROTO_UPSTREAM_HOST=127.0.0.1
TRACEGATE_MTPROTO_UPSTREAM_PORT=9443
# Required when the official MTProxy binary is hidden behind local TCP/443 fronting.
# Example: TRACEGATE_MTPROTO_BIND_ADDRESS=127.0.0.1
# Example: TRACEGATE_MTPROTO_NAT_INFO=127.0.0.1:203.0.113.10
TRACEGATE_MTPROTO_BIND_ADDRESS=
TRACEGATE_MTPROTO_NAT_INFO=
TRACEGATE_MTPROTO_TLS_MODE=private-fronting
TRACEGATE_MTPROTO_SECRET_FILE=/etc/tracegate/private/mtproto/secret.txt
TRACEGATE_MTPROTO_STATE_DIR=/var/lib/tracegate/private/mtproto
TRACEGATE_MTPROTO_ISSUED_STATE_FILE=/var/lib/tracegate/private/mtproto/issued.json
TRACEGATE_MTPROTO_RUNNER=/opt/mtproto-private/tracegate-mtproto-gateway
TRACEGATE_MTPROTO_FORCE_OFFICIAL=false
TRACEGATE_MTPROTO_BINARY=/opt/MTProxy/objs/bin/mtproto-proxy
TRACEGATE_MTPROTO_RUNTIME_DIR=/var/lib/tracegate/private/mtproto/runtime
TRACEGATE_MTPROTO_STATS_PORT=9888
TRACEGATE_MTPROTO_RUN_AS_USER=nobody
TRACEGATE_MTPROTO_WORKERS=0
TRACEGATE_MTPROTO_PID_NAMESPACE=auto
TRACEGATE_MTPROTO_PROXY_TAG=
TRACEGATE_MTPROTO_FETCH_SECRET_URL=https://core.telegram.org/getProxySecret
TRACEGATE_MTPROTO_FETCH_CONFIG_URL=https://core.telegram.org/getProxyConfig
TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS=86400
TRACEGATE_MTPROTO_PROXY_SECRET_FILE=/var/lib/tracegate/private/mtproto/runtime/proxy-secret
TRACEGATE_MTPROTO_PROXY_CONFIG_FILE=/var/lib/tracegate/private/mtproto/runtime/proxy-multi.conf
TRACEGATE_MTPROTO_PID_FILE=/var/lib/tracegate/private/mtproto/runtime/mtproto-proxy.pid
TRACEGATE_MTPROTO_LOG_FILE=/var/lib/tracegate/private/mtproto/runtime/mtproto-proxy.log
TRACEGATE_MTPROTO_NOTES="Enable only after Transit TCP/443 fronting is ready. If no out-of-tree runner exists, the wrapper can supervise the official local MTProxy binary directly and reload it when account-bound MTProto grants rotate."
