#!/usr/bin/env bash
set -euo pipefail

ACTION="${1:-start}"
ROLE="${2:-unknown}"

CONFIG_DIR="${CONFIG_DIR:-/etc/tracegate}"
TRACEGATE_APP_ROOT="${TRACEGATE_APP_ROOT:-/opt/tracegate}"
TRACEGATE_PRIVATE_RUNTIME_DIR="${TRACEGATE_PRIVATE_RUNTIME_DIR:-/var/lib/tracegate/private}"
TRACEGATE_MTPROTO_ENABLED="${TRACEGATE_MTPROTO_ENABLED:-false}"
TRACEGATE_MTPROTO_BACKEND="${TRACEGATE_MTPROTO_BACKEND:-private}"
TRACEGATE_MTPROTO_RUNTIME_STATE_JSON="${TRACEGATE_MTPROTO_RUNTIME_STATE_JSON:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/obfuscation/${ROLE}/runtime-state.json}"
TRACEGATE_MTPROTO_PROFILE_FILE="${TRACEGATE_MTPROTO_PROFILE_FILE:-${CONFIG_DIR}/private/zapret/mtproto-extra.env}"
TRACEGATE_MTPROTO_DOMAIN="${TRACEGATE_MTPROTO_DOMAIN:-proxied.tracegate.su}"
TRACEGATE_MTPROTO_PUBLIC_PORT="${TRACEGATE_MTPROTO_PUBLIC_PORT:-443}"
TRACEGATE_MTPROTO_UPSTREAM_HOST="${TRACEGATE_MTPROTO_UPSTREAM_HOST:-127.0.0.1}"
TRACEGATE_MTPROTO_UPSTREAM_PORT="${TRACEGATE_MTPROTO_UPSTREAM_PORT:-9443}"
TRACEGATE_MTPROTO_BIND_ADDRESS="${TRACEGATE_MTPROTO_BIND_ADDRESS:-}"
TRACEGATE_MTPROTO_NAT_INFO="${TRACEGATE_MTPROTO_NAT_INFO:-}"
TRACEGATE_MTPROTO_SECRET_FILE="${TRACEGATE_MTPROTO_SECRET_FILE:-${CONFIG_DIR}/private/mtproto/secret.txt}"
TRACEGATE_MTPROTO_STATE_DIR="${TRACEGATE_MTPROTO_STATE_DIR:-${TRACEGATE_PRIVATE_RUNTIME_DIR}/mtproto}"
TRACEGATE_MTPROTO_PUBLIC_PROFILE_FILE="${TRACEGATE_MTPROTO_PUBLIC_PROFILE_FILE:-${TRACEGATE_MTPROTO_STATE_DIR}/public-profile.json}"
TRACEGATE_MTPROTO_ISSUED_STATE_FILE="${TRACEGATE_MTPROTO_ISSUED_STATE_FILE:-${TRACEGATE_MTPROTO_STATE_DIR}/issued.json}"
TRACEGATE_MTPROTO_RUNNER="${TRACEGATE_MTPROTO_RUNNER:-/opt/mtproto-private/tracegate-mtproto-gateway}"
TRACEGATE_MTPROTO_FORCE_OFFICIAL="${TRACEGATE_MTPROTO_FORCE_OFFICIAL:-false}"
TRACEGATE_MTPROTO_TLS_MODE="${TRACEGATE_MTPROTO_TLS_MODE:-private-fronting}"
TRACEGATE_MTPROTO_BINARY="${TRACEGATE_MTPROTO_BINARY:-/opt/MTProxy/objs/bin/mtproto-proxy}"
TRACEGATE_MTPROTO_RUNTIME_DIR="${TRACEGATE_MTPROTO_RUNTIME_DIR:-${TRACEGATE_MTPROTO_STATE_DIR}/runtime}"
TRACEGATE_MTPROTO_STATS_PORT="${TRACEGATE_MTPROTO_STATS_PORT:-9888}"
TRACEGATE_MTPROTO_RUN_AS_USER="${TRACEGATE_MTPROTO_RUN_AS_USER:-nobody}"
TRACEGATE_MTPROTO_WORKERS="${TRACEGATE_MTPROTO_WORKERS:-0}"
TRACEGATE_MTPROTO_PID_NAMESPACE="${TRACEGATE_MTPROTO_PID_NAMESPACE:-auto}"
TRACEGATE_MTPROTO_PROXY_TAG="${TRACEGATE_MTPROTO_PROXY_TAG:-}"
TRACEGATE_MTPROTO_FETCH_SECRET_URL="${TRACEGATE_MTPROTO_FETCH_SECRET_URL:-https://core.telegram.org/getProxySecret}"
TRACEGATE_MTPROTO_FETCH_CONFIG_URL="${TRACEGATE_MTPROTO_FETCH_CONFIG_URL:-https://core.telegram.org/getProxyConfig}"
TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS="${TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS:-86400}"
TRACEGATE_MTPROTO_PROXY_SECRET_FILE="${TRACEGATE_MTPROTO_PROXY_SECRET_FILE:-${TRACEGATE_MTPROTO_RUNTIME_DIR}/proxy-secret}"
TRACEGATE_MTPROTO_PROXY_CONFIG_FILE="${TRACEGATE_MTPROTO_PROXY_CONFIG_FILE:-${TRACEGATE_MTPROTO_RUNTIME_DIR}/proxy-multi.conf}"
TRACEGATE_MTPROTO_PID_FILE="${TRACEGATE_MTPROTO_PID_FILE:-${TRACEGATE_MTPROTO_RUNTIME_DIR}/mtproto-proxy.pid}"
TRACEGATE_MTPROTO_LOG_FILE="${TRACEGATE_MTPROTO_LOG_FILE:-${TRACEGATE_MTPROTO_RUNTIME_DIR}/mtproto-proxy.log}"
TRACEGATE_PYTHON_BIN="${TRACEGATE_PYTHON_BIN:-${TRACEGATE_APP_ROOT}/.venv/bin/python}"

if [[ ! -x "${TRACEGATE_PYTHON_BIN}" ]]; then
  TRACEGATE_PYTHON_BIN="$(command -v python3 || true)"
fi
if [[ -z "${TRACEGATE_PYTHON_BIN}" ]]; then
  echo "tracegate mtproto cannot find python interpreter"
  exit 1
fi

mkdir -p "${TRACEGATE_MTPROTO_STATE_DIR}" "${TRACEGATE_MTPROTO_RUNTIME_DIR}"

"${TRACEGATE_PYTHON_BIN}" - "${TRACEGATE_MTPROTO_STATE_DIR}" "${ACTION}" "${ROLE}" "${TRACEGATE_MTPROTO_DOMAIN}" "${TRACEGATE_MTPROTO_PUBLIC_PORT}" "${TRACEGATE_MTPROTO_UPSTREAM_HOST}" "${TRACEGATE_MTPROTO_UPSTREAM_PORT}" "${TRACEGATE_MTPROTO_PROFILE_FILE}" "${TRACEGATE_MTPROTO_RUNTIME_STATE_JSON}" "${TRACEGATE_MTPROTO_BACKEND}" "${TRACEGATE_MTPROTO_PUBLIC_PROFILE_FILE}" "${TRACEGATE_MTPROTO_ISSUED_STATE_FILE}" <<'PY'
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path

state_dir = Path(sys.argv[1])
payload = {
    "timestamp": datetime.now(timezone.utc).isoformat(),
    "action": sys.argv[2],
    "role": sys.argv[3],
    "backend": sys.argv[10].strip().lower(),
    "domain": sys.argv[4],
    "publicPort": sys.argv[5],
    "upstreamHost": sys.argv[6],
    "upstreamPort": sys.argv[7],
    "profileFile": sys.argv[8],
    "runtimeStateJson": sys.argv[9],
    "publicProfileFile": sys.argv[11],
    "issuedStateFile": sys.argv[12],
}
state_dir.mkdir(parents=True, exist_ok=True)
(state_dir / "last-action.json").write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY

write_public_profile() {
  [[ -s "${TRACEGATE_MTPROTO_SECRET_FILE}" ]] || return 0

  "${TRACEGATE_PYTHON_BIN}" - "${TRACEGATE_MTPROTO_PUBLIC_PROFILE_FILE}" "${TRACEGATE_MTPROTO_DOMAIN}" "${TRACEGATE_MTPROTO_PUBLIC_PORT}" "${TRACEGATE_MTPROTO_SECRET_FILE}" <<'PY'
from __future__ import annotations

import json
import sys
from pathlib import Path

from tracegate.services.mtproto import build_mtproto_share_links, load_mtproto_server_secret

profile_path = Path(sys.argv[1])
domain = sys.argv[2].strip()
port = int(sys.argv[3])
secret_file = Path(sys.argv[4])
secret_hex = load_mtproto_server_secret(secret_file)
links = build_mtproto_share_links(
    server=domain,
    port=port,
    secret_hex=secret_hex,
    transport="tls",
    domain=domain,
)
payload = {
    "protocol": "mtproto",
    "server": domain,
    "port": port,
    "transport": "tls",
    "domain": domain,
    "secret": secret_hex,
    "clientSecretHex": links.client_secret_hex,
    "tgUri": links.tg_uri,
    "httpsUrl": links.https_url,
}
profile_path.parent.mkdir(parents=True, exist_ok=True)
profile_path.write_text(json.dumps(payload, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
PY
}

is_running() {
  local -a pids=()
  mapfile -t pids < <(find_mtproto_pids)
  [[ "${#pids[@]}" -gt 0 ]]
}

find_mtproto_listener_pids() {
  local port="${TRACEGATE_MTPROTO_UPSTREAM_PORT}"
  ss -lntp "( sport = :${port} )" 2>/dev/null \
    | awk '
        {
          line = $0
          while (match(line, /pid=[0-9]+/)) {
            print substr(line, RSTART + 4, RLENGTH - 4)
            line = substr(line, RSTART + RLENGTH)
          }
        }
      ' \
    | awk '!seen[$0]++'
}

find_mtproto_process_pids() {
  ps -eo pid=,args= \
    | awk -v binary="${TRACEGATE_MTPROTO_BINARY}" -v port="${TRACEGATE_MTPROTO_UPSTREAM_PORT}" '
        index($0, binary) && $0 ~ ("(^|[[:space:]])-H[[:space:]]*" port "([[:space:]]|$)") {
          print $1
        }
      ' \
    | awk '!seen[$0]++'
}

find_mtproto_pids() {
  {
    if [[ -f "${TRACEGATE_MTPROTO_PID_FILE}" ]]; then
      cat "${TRACEGATE_MTPROTO_PID_FILE}" 2>/dev/null || true
    fi
    find_mtproto_listener_pids
    find_mtproto_process_pids
  } | awk '
        {
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
          if ($0 ~ /^[0-9]+$/ && !seen[$0]++) {
            print $0
          }
        }
      '
}

use_private_runner() {
  case "${TRACEGATE_MTPROTO_FORCE_OFFICIAL,,}" in
    true|yes|1) return 1 ;;
  esac
  [[ -x "${TRACEGATE_MTPROTO_RUNNER}" ]]
}

stop_local_proxy() {
  local -a pids=()
  mapfile -t pids < <(find_mtproto_pids)
  if [[ "${#pids[@]}" -eq 0 ]]; then
    rm -f "${TRACEGATE_MTPROTO_PID_FILE}"
    echo "tracegate mtproto not running"
    return 0
  fi

  kill "${pids[@]}" 2>/dev/null || true
  for _ in $(seq 1 25); do
    local any_running="false"
    for pid in "${pids[@]}"; do
      if kill -0 "${pid}" 2>/dev/null; then
        any_running="true"
        break
      fi
    done
    if [[ "${any_running}" != "true" ]]; then
      break
    fi
    sleep 0.2
  done

  local -a stubborn_pids=()
  for pid in "${pids[@]}"; do
    if kill -0 "${pid}" 2>/dev/null; then
      stubborn_pids+=("${pid}")
    fi
  done
  if [[ "${#stubborn_pids[@]}" -gt 0 ]]; then
    kill -9 "${stubborn_pids[@]}" 2>/dev/null || true
  fi

  rm -f "${TRACEGATE_MTPROTO_PID_FILE}"
  echo "tracegate mtproto stopped"
}

ensure_secret_file() {
  "${TRACEGATE_PYTHON_BIN}" - "${TRACEGATE_MTPROTO_SECRET_FILE}" <<'PY'
from __future__ import annotations

import secrets
import sys
from pathlib import Path

path = Path(sys.argv[1])
path.parent.mkdir(parents=True, exist_ok=True)
if path.is_file():
    raw = "".join(ch for ch in path.read_text(encoding="utf-8") if ch.lower() in "0123456789abcdef").lower()
    if len(raw) == 32:
        raise SystemExit(0)
path.write_text(secrets.token_hex(16) + "\n", encoding="utf-8")
path.chmod(0o600)
PY
}

refresh_bootstrap_file() {
  local url="$1"
  local path="$2"
  local max_age="$3"

  "${TRACEGATE_PYTHON_BIN}" - "${url}" "${path}" "${max_age}" <<'PY'
from __future__ import annotations

import sys
import time
from pathlib import Path
from urllib.request import Request, urlopen

url = str(sys.argv[1]).strip()
path = Path(sys.argv[2])
max_age = max(60, int(sys.argv[3]))

if path.is_file():
    age = time.time() - path.stat().st_mtime
    if age < max_age and path.stat().st_size > 0:
        raise SystemExit(0)

path.parent.mkdir(parents=True, exist_ok=True)
request = Request(url, headers={"User-Agent": "Tracegate/2 private MTProto wrapper"})
with urlopen(request, timeout=15) as response:  # noqa: S310
    payload = response.read()
if not payload:
    raise SystemExit(f"empty bootstrap payload from {url}")
path.write_bytes(payload)
PY
}

build_official_command() {
  "${TRACEGATE_PYTHON_BIN}" - \
    "${TRACEGATE_MTPROTO_BINARY}" \
    "${TRACEGATE_MTPROTO_RUN_AS_USER}" \
    "${TRACEGATE_MTPROTO_STATS_PORT}" \
    "${TRACEGATE_MTPROTO_UPSTREAM_PORT}" \
    "${TRACEGATE_MTPROTO_SECRET_FILE}" \
    "${TRACEGATE_MTPROTO_ISSUED_STATE_FILE}" \
    "${TRACEGATE_MTPROTO_PROXY_SECRET_FILE}" \
    "${TRACEGATE_MTPROTO_PROXY_CONFIG_FILE}" \
    "${TRACEGATE_MTPROTO_WORKERS}" \
    "${TRACEGATE_MTPROTO_PROXY_TAG}" \
    "${TRACEGATE_MTPROTO_TLS_MODE}" \
    "${TRACEGATE_MTPROTO_DOMAIN}" \
    "${TRACEGATE_MTPROTO_BIND_ADDRESS}" \
    "${TRACEGATE_MTPROTO_NAT_INFO}" <<'PY'
from __future__ import annotations

import sys

from tracegate.services.mtproto import (
    build_mtproto_official_proxy_command,
    load_mtproto_issued_secret_hexes,
    load_mtproto_server_secret,
)

command = build_mtproto_official_proxy_command(
    binary=sys.argv[1],
    run_as_user=sys.argv[2],
    stats_port=int(sys.argv[3]),
    listen_port=int(sys.argv[4]),
    primary_secret_hex=load_mtproto_server_secret(sys.argv[5]),
    issued_secret_hexes=load_mtproto_issued_secret_hexes(sys.argv[6]),
    proxy_secret_file=sys.argv[7],
    proxy_config_file=sys.argv[8],
    workers=int(sys.argv[9]),
    proxy_tag=sys.argv[10],
    tls_mode=sys.argv[11],
    domain=sys.argv[12],
    bind_address=sys.argv[13],
    nat_info=sys.argv[14],
)
for arg in command.argv:
    print(arg)
PY
}

start_official_binary() {
  refresh_bootstrap_file "${TRACEGATE_MTPROTO_FETCH_SECRET_URL}" "${TRACEGATE_MTPROTO_PROXY_SECRET_FILE}" "${TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS}"
  refresh_bootstrap_file "${TRACEGATE_MTPROTO_FETCH_CONFIG_URL}" "${TRACEGATE_MTPROTO_PROXY_CONFIG_FILE}" "${TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS}"
  ensure_secret_file
  write_public_profile

  local -a cmd=()
  mapfile -t cmd < <(build_official_command)
  if [[ "${#cmd[@]}" -eq 0 ]]; then
    echo "tracegate mtproto failed to build command"
    exit 1
  fi

  if is_running; then
    stop_local_proxy >/dev/null
  fi

  local -a launch_cmd=("${cmd[@]}")
  local pid_namespace="${TRACEGATE_MTPROTO_PID_NAMESPACE,,}"
  if [[ "${pid_namespace}" == "true" || "${pid_namespace}" == "yes" || "${pid_namespace}" == "1" || "${pid_namespace}" == "auto" ]]; then
    if command -v unshare >/dev/null 2>&1; then
      # Official MTProxy stores the process id in a 16-bit field and can crash on long-lived hosts.
      # A private PID namespace keeps the proxy PID small without requiring a host reboot.
      launch_cmd=(unshare --pid --fork --mount-proc "${cmd[@]}")
    elif [[ "${pid_namespace}" != "auto" ]]; then
      echo "tracegate mtproto pid namespace requested but unshare is not installed"
      exit 1
    fi
  fi

  nohup "${launch_cmd[@]}" >>"${TRACEGATE_MTPROTO_LOG_FILE}" 2>&1 &
  local launcher_pid="$!"
  local pid=""
  for _ in $(seq 1 20); do
    mapfile -t listener_pids < <(find_mtproto_listener_pids)
    if [[ "${#listener_pids[@]}" -gt 0 ]]; then
      pid="${listener_pids[0]}"
      break
    fi
    if ! kill -0 "${launcher_pid}" 2>/dev/null; then
      break
    fi
    sleep 0.2
  done
  if [[ -z "${pid}" && -n "${launcher_pid}" ]]; then
    if kill -0 "${launcher_pid}" 2>/dev/null; then
      pid="${launcher_pid}"
    fi
  fi
  if [[ -z "${pid}" ]]; then
    echo "tracegate mtproto failed to start official binary"
    echo "log_file=${TRACEGATE_MTPROTO_LOG_FILE}"
    exit 1
  fi
  if ! kill -0 "${pid}" 2>/dev/null; then
    echo "tracegate mtproto failed to start official binary"
    echo "log_file=${TRACEGATE_MTPROTO_LOG_FILE}"
    exit 1
  fi
  echo "${pid}" > "${TRACEGATE_MTPROTO_PID_FILE}"

  if [[ "${ACTION}" == "reload" ]]; then
    echo "tracegate mtproto reloaded"
  else
    echo "tracegate mtproto started"
  fi
  echo "binary=${TRACEGATE_MTPROTO_BINARY}"
  echo "pid_file=${TRACEGATE_MTPROTO_PID_FILE}"
  echo "log_file=${TRACEGATE_MTPROTO_LOG_FILE}"
}

if [[ "${ACTION}" == "stop" ]]; then
  if use_private_runner; then
    TRACEGATE_MTPROTO_RUNTIME_STATE_JSON="${TRACEGATE_MTPROTO_RUNTIME_STATE_JSON}" \
    TRACEGATE_MTPROTO_PROFILE_FILE="${TRACEGATE_MTPROTO_PROFILE_FILE}" \
    TRACEGATE_MTPROTO_SECRET_FILE="${TRACEGATE_MTPROTO_SECRET_FILE}" \
    TRACEGATE_MTPROTO_ISSUED_STATE_FILE="${TRACEGATE_MTPROTO_ISSUED_STATE_FILE}" \
    "${TRACEGATE_MTPROTO_RUNNER}" "${ACTION}" "${ROLE}" || true
  fi
  stop_local_proxy
  exit 0
fi

if [[ "${TRACEGATE_MTPROTO_ENABLED,,}" != "true" ]]; then
  echo "tracegate mtproto disabled"
  echo "action=${ACTION}"
  echo "role=${ROLE}"
  echo "domain=${TRACEGATE_MTPROTO_DOMAIN}"
  echo "public_port=${TRACEGATE_MTPROTO_PUBLIC_PORT}"
  exit 0
fi

ensure_secret_file
write_public_profile

if use_private_runner; then
  refresh_bootstrap_file "${TRACEGATE_MTPROTO_FETCH_SECRET_URL}" "${TRACEGATE_MTPROTO_PROXY_SECRET_FILE}" "${TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS}"
  refresh_bootstrap_file "${TRACEGATE_MTPROTO_FETCH_CONFIG_URL}" "${TRACEGATE_MTPROTO_PROXY_CONFIG_FILE}" "${TRACEGATE_MTPROTO_BOOTSTRAP_MAX_AGE_SECONDS}"
  TRACEGATE_MTPROTO_RUNTIME_STATE_JSON="${TRACEGATE_MTPROTO_RUNTIME_STATE_JSON}" \
  TRACEGATE_MTPROTO_PROFILE_FILE="${TRACEGATE_MTPROTO_PROFILE_FILE}" \
  TRACEGATE_MTPROTO_SECRET_FILE="${TRACEGATE_MTPROTO_SECRET_FILE}" \
  TRACEGATE_MTPROTO_ISSUED_STATE_FILE="${TRACEGATE_MTPROTO_ISSUED_STATE_FILE}" \
  TRACEGATE_MTPROTO_PROXY_SECRET_FILE="${TRACEGATE_MTPROTO_PROXY_SECRET_FILE}" \
  TRACEGATE_MTPROTO_PROXY_CONFIG_FILE="${TRACEGATE_MTPROTO_PROXY_CONFIG_FILE}" \
  "${TRACEGATE_MTPROTO_RUNNER}" "${ACTION}" "${ROLE}"
  echo "tracegate mtproto delegated to private runner"
  exit 0
fi

if [[ ! -x "${TRACEGATE_MTPROTO_BINARY}" ]]; then
  echo "tracegate mtproto official binary not installed: ${TRACEGATE_MTPROTO_BINARY}"
  echo "backend=${TRACEGATE_MTPROTO_BACKEND}"
  echo "profile_file=${TRACEGATE_MTPROTO_PROFILE_FILE}"
  echo "runtime_state_json=${TRACEGATE_MTPROTO_RUNTIME_STATE_JSON}"
  exit 1
fi

start_official_binary
