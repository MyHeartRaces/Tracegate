# Private TCP/443 fronting contract for Transit.
# Keep the actual demux implementation private.
TRACEGATE_FRONTING_ENABLED=false
TRACEGATE_FRONTING_ROLE=transit
TRACEGATE_FRONTING_BACKEND=private
TRACEGATE_PRIVATE_RUNTIME_DIR=/var/lib/tracegate/private
TRACEGATE_FRONTING_LISTEN_ADDR=:443
TRACEGATE_FRONTING_PROTOCOL=tcp
TRACEGATE_FRONTING_REALITY_UPSTREAM=127.0.0.1:2443
TRACEGATE_FRONTING_WS_TLS_UPSTREAM=127.0.0.1:4443
TRACEGATE_FRONTING_MTPROTO_UPSTREAM=127.0.0.1:9443
TRACEGATE_FRONTING_MTPROTO_PROFILE_FILE=/etc/tracegate/private/zapret/mtproto-extra.env
TRACEGATE_FRONTING_RUNTIME_STATE_JSON=/var/lib/tracegate/private/obfuscation/transit/runtime-state.json
TRACEGATE_FRONTING_TOUCH_UDP_443=false
TRACEGATE_FRONTING_NOTES=Transit private fronting should keep public UDP/8443 on the Hysteria2 runtime owner, only own TCP/443 demux, and send MTProto to a dedicated real-domain backend.
