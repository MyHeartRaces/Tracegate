AGENT_HOST=0.0.0.0
AGENT_PORT=8070
AGENT_DRY_RUN=false
AGENT_DATA_ROOT=/var/lib/tracegate/agent-entry
# Optional: override when private handoff surfaces should not live under /var/lib/tracegate/private.
# PRIVATE_RUNTIME_ROOT=/var/lib/tracegate/private
PRIVATE_OBFUSCATION_BACKEND=zapret2
PRIVATE_ENTRY_INTERFACE=eth0

# Transit-side Hysteria metrics are sourced from Xray stats in the xray-centric runtime.
AGENT_STATS_URL=http://127.0.0.1:9999/traffic
AGENT_STATS_SECRET=REPLACE_ME

# Xray live user updates on Entry
AGENT_XRAY_API_ENABLED=true
AGENT_XRAY_API_SERVER=127.0.0.1:8080
AGENT_XRAY_API_TIMEOUT_SECONDS=3

# Local runtime reload hooks
AGENT_RELOAD_XRAY_CMD=systemctl restart tracegate-xray@entry
AGENT_RELOAD_HAPROXY_CMD=systemctl restart tracegate-haproxy@entry
AGENT_RELOAD_NGINX_CMD=systemctl reload tracegate-nginx@entry || systemctl restart tracegate-nginx@entry
# Optional: reload a host-local zapret2 / FinalMask wrapper when runtime-contract.json changes.
AGENT_RELOAD_OBFUSCATION_CMD=systemctl reload tracegate-obfuscation@entry || systemctl restart tracegate-obfuscation@entry
# Private helpers are safe no-ops until their private env files enable them.
AGENT_RELOAD_PROFILES_CMD=systemctl reload tracegate-profiles@entry || systemctl restart tracegate-profiles@entry
AGENT_RELOAD_LINK_CRYPTO_CMD=systemctl reload tracegate-link-crypto@entry || systemctl restart tracegate-link-crypto@entry

PRIVATE_MIERU_PROFILE_DIR=/etc/tracegate/private/mieru
PRIVATE_MIERU_CLIENT_PROFILE=client.json
PRIVATE_LINK_CRYPTO_ENABLED=true
PRIVATE_LINK_CRYPTO_GENERATION=1
PRIVATE_LINK_CRYPTO_BIND_HOST=127.0.0.1
PRIVATE_LINK_CRYPTO_ENTRY_PORT=10881
PRIVATE_LINK_CRYPTO_REMOTE_PORT=443
PRIVATE_LINK_CRYPTO_ZAPRET2_ENABLED=false

# Private TCP/443 demux must never claim UDP/443 on Entry either.
FRONTING_TOUCH_UDP_443=false

# Optional dedicated V2 chain backend split
AGENT_ENTRY_V2_SPLIT_BACKEND_ENABLED=false
