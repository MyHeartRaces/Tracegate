#!/usr/bin/env bash
set -euo pipefail

# Renders the Entry-side ShadowTLS v3 backhaul client environment from the
# operator runtime env. The client wraps the loopback SS2022 outbound
# (127.0.0.1:15443) into a ShadowTLS session to the Endpoint backhaul listener.

runtime_env="${TRACEGATE_ENV_FILE:-/etc/tracegate/tracegate-entry.env}"
target_env="${TRACEGATE_SHADOWTLS_ENTRY_ENV_FILE:-/etc/tracegate/private/shadowtls/entry.env}"

test -f "${runtime_env}" || {
  echo "tracegate shadowtls entry env: missing ${runtime_env}" >&2
  exit 1
}

set -a
# shellcheck disable=SC1090
source "${runtime_env}"
set +a

remote_target="${SHADOWTLS_BACKHAUL_TARGET:-}"
target="${SHADOWTLS_BACKHAUL_FRAGMENT1_LISTEN:-127.0.0.1:16443}"
sni="${SHADOWTLS_BACKHAUL_SNI:-${SHADOWTLS_BACKHAUL_SERVER_NAME:-}}"
password="${SHADOWTLS_BACKHAUL_PASSWORD:-}"
if [[ "${remote_target}" != *:* ]]; then
  remote_target="${remote_target}:9443"
fi
test -n "${remote_target%%:*}" || {
  echo "tracegate shadowtls entry env: SHADOWTLS_BACKHAUL_TARGET is missing" >&2
  exit 1
}
[[ "${target}" == 127.*:* || "${target}" == "[::1]:"* ]] || {
  echo "tracegate shadowtls entry env: fragment listener must be loopback" >&2
  exit 1
}
test -n "${sni}" || {
  echo "tracegate shadowtls entry env: SHADOWTLS_BACKHAUL_SNI is missing" >&2
  exit 1
}
test -n "${password}" || {
  echo "tracegate shadowtls entry env: SHADOWTLS_BACKHAUL_PASSWORD is missing" >&2
  exit 1
}

install -d -m 0700 "$(dirname -- "${target_env}")"
tmp="${target_env}.tmp"
umask 077
printf 'SHADOWTLS_BACKHAUL_TARGET=%q\nSHADOWTLS_BACKHAUL_SNI=%q\nSHADOWTLS_BACKHAUL_PASSWORD=%q\n' \
  "${target}" "${sni}" "${password}" >"${tmp}"
chmod 0600 "${tmp}"
mv -f "${tmp}" "${target_env}"
