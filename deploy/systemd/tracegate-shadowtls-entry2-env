#!/usr/bin/env bash
set -euo pipefail

# Renders the Entry-side ShadowTLS v3 backhaul client #2 environment (pool leg 2).
# Wraps the loopback SS2022 outbound (127.0.0.1:15444) into a ShadowTLS session to
# the Endpoint leg-2 backhaul listener, presenting the leg-2 front SNI.

runtime_env="${TRACEGATE_ENV_FILE:-/etc/tracegate/tracegate-entry.env}"
target_env="${TRACEGATE_SHADOWTLS_ENTRY2_ENV_FILE:-/etc/tracegate/private/shadowtls/entry2.env}"

test -f "${runtime_env}" || {
  echo "tracegate shadowtls entry2 env: missing ${runtime_env}" >&2
  exit 1
}

set -a
# shellcheck disable=SC1090
source "${runtime_env}"
set +a

remote_target="${SHADOWTLS_BACKHAUL2_TARGET:-}"
target="${SHADOWTLS_BACKHAUL_FRAGMENT2_LISTEN:-127.0.0.1:16444}"
sni="${SHADOWTLS_BACKHAUL2_SNI:-}"
password="${SHADOWTLS_BACKHAUL2_PASSWORD:-${SHADOWTLS_BACKHAUL_PASSWORD:-}}"
if [[ "${remote_target}" != *:* ]]; then
  remote_target="${remote_target}:9444"
fi
test -n "${remote_target%%:*}" || {
  echo "tracegate shadowtls entry2 env: SHADOWTLS_BACKHAUL2_TARGET is missing" >&2
  exit 1
}
[[ "${target}" == 127.*:* || "${target}" == "[::1]:"* ]] || {
  echo "tracegate shadowtls entry2 env: fragment listener must be loopback" >&2
  exit 1
}
test -n "${sni}" || {
  echo "tracegate shadowtls entry2 env: SHADOWTLS_BACKHAUL2_SNI is missing" >&2
  exit 1
}
test -n "${password}" || {
  echo "tracegate shadowtls entry2 env: password is missing" >&2
  exit 1
}

install -d -m 0700 "$(dirname -- "${target_env}")"
tmp="${target_env}.tmp"
umask 077
printf 'SHADOWTLS_BACKHAUL2_TARGET=%q\nSHADOWTLS_BACKHAUL2_SNI=%q\nSHADOWTLS_BACKHAUL2_PASSWORD=%q\n' \
  "${target}" "${sni}" "${password}" >"${tmp}"
chmod 0600 "${tmp}"
mv -f "${tmp}" "${target_env}"
