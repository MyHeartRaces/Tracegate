# Client-facing ShadowTLS v3 server (Experimental SS2022 profile).
SHADOWTLS_TLS_TARGET=REPLACE_WITH_DECOY_HOST:443
SHADOWTLS_PASSWORD=REPLACE_WITH_PRIVATE_PASSWORD

# Entry<->Endpoint SS2022 + ShadowTLS v3 primary backhaul (source-gated pool).
# Present these in the shared runtime env (/etc/tracegate/tracegate.env) so the
# Entry client and Endpoint server units render a matching session. When the
# SS2022 backhaul key is absent the pool degrades to the REALITY-RAW leg only.
#   Endpoint server:  tcp/9443, forwards to the isolated ss2022-backhaul-in.
#   Entry client:     127.0.0.1:15443 -> Endpoint:9443, SNI = ibtcom.ru.
SHADOWTLS_BACKHAUL_SNI=ibtcom.ru
SHADOWTLS_BACKHAUL_TLS_TARGET=ibtcom.ru:443
SHADOWTLS_BACKHAUL_PASSWORD=REPLACE_WITH_PRIVATE_BACKHAUL_PASSWORD
SHADOWTLS_BACKHAUL_TARGET=REPLACE_WITH_ENDPOINT_HOST:9443
SHADOWTLS_BACKHAUL_LISTEN=0.0.0.0:9443
# 32-byte base64 aes-256 key shared by the Entry to-transit-ss outbound and the
# Endpoint ss2022-backhaul-in inbound.
SHADOWSOCKS2022_BACKHAUL_KEY=REPLACE_WITH_BASE64_32BYTE_KEY
# Dedicated source-gated port for the VLESS/REALITY fallback leg. Multiplexed
# Chain streams land here instead of sharing the client-facing tcp/443 ingress.
REALITY_BACKHAUL_PORT=9446
