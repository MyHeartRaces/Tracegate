#!/usr/bin/env bash
set -euo pipefail

# Renders the Endpoint-side ShadowTLS v3 backhaul server #2 environment (pool leg 2,
# a second ShadowTLS front on a dedicated source-gated port). Mirrors the leg-1
# renderer but reads the SHADOWTLS_BACKHAUL2_* keys and forwards the decapsulated
# stream to the same isolated SS2022 backhaul inbound (127.0.0.1:18444).

runtime_env="${TRACEGATE_ENV_FILE:-/etc/tracegate/tracegate.env}"
target_env="${TRACEGATE_SHADOWTLS_BACKHAUL2_ENV_FILE:-/etc/tracegate/private/shadowtls/backhaul2.env}"

test -f "${runtime_env}" || {
  echo "tracegate shadowtls backhaul2 env: missing ${runtime_env}" >&2
  exit 1
}

set -a
# shellcheck disable=SC1090
source "${runtime_env}"
set +a

listen="${SHADOWTLS_BACKHAUL2_LISTEN:-0.0.0.0:9444}"
tls_target="${SHADOWTLS_BACKHAUL2_TLS_TARGET:-${SHADOWTLS_BACKHAUL2_SNI:-}}"
password="${SHADOWTLS_BACKHAUL2_PASSWORD:-${SHADOWTLS_BACKHAUL_PASSWORD:-}}"
if [[ "${listen}" != *:* ]]; then
  listen="0.0.0.0:${listen}"
fi
if [[ "${tls_target}" != *:* ]]; then
  tls_target="${tls_target}:443"
fi
test -n "${tls_target%%:*}" || {
  echo "tracegate shadowtls backhaul2 env: TLS target is missing" >&2
  exit 1
}
test -n "${password}" || {
  echo "tracegate shadowtls backhaul2 env: password is missing" >&2
  exit 1
}

install -d -m 0700 "$(dirname -- "${target_env}")"
tmp="${target_env}.tmp"
umask 077
printf 'SHADOWTLS_BACKHAUL2_LISTEN=%q\nSHADOWTLS_BACKHAUL2_TLS_TARGET=%q\nSHADOWTLS_BACKHAUL2_PASSWORD=%q\n' \
  "${listen}" "${tls_target}" "${password}" >"${tmp}"
chmod 0600 "${tmp}"
mv -f "${tmp}" "${target_env}"
