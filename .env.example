APP_ENV=dev
LOG_LEVEL=INFO

# Bootstrap superadmin Telegram IDs (JSON list).
# Example: SUPERADMIN_TELEGRAM_IDS=[123456789]
SUPERADMIN_TELEGRAM_IDS=[]

# Local dev (docker compose) uses these by default.
POSTGRES_DB=tracegate
POSTGRES_USER=tracegate
POSTGRES_PASSWORD=REPLACE_ME

# For docker compose use host `postgres`; for local host use `localhost`.
DATABASE_URL=postgresql+asyncpg://tracegate:REPLACE_ME@postgres:5432/tracegate

API_HOST=0.0.0.0
API_PORT=8080
API_INTERNAL_TOKEN=REPLACE_ME

# Public URL of the control-plane (used by bot links, e.g. Grafana OTP login).
PUBLIC_BASE_URL=http://localhost:8080

# Bundles root (container image includes ./bundles by default).
BUNDLE_ROOT=bundles
BUNDLE_PRIVATE_OVERLAY_ROOT=
TRACEGATE_PRIVATE_RENDER_HOOK=
# Shared decoy root for nginx and Xray-native Hysteria masquerade.
XRAY_CENTRIC_DECOY_DIR=/var/www/decoy
# Optional private files for Xray-native Hysteria obfuscation.
# Keep the actual FinalMask/ECH payloads outside the repo.
XRAY_HYSTERIA_FINALMASK_FILE=
XRAY_HYSTERIA_FINALMASK_ENTRY_FILE=
XRAY_HYSTERIA_FINALMASK_TRANSIT_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_ENTRY_FILE=
XRAY_HYSTERIA_ECH_SERVER_KEYS_TRANSIT_FILE=

DISPATCHER_HOST=0.0.0.0
DISPATCHER_PORT=8090
DISPATCHER_POLL_SECONDS=3
DISPATCHER_BATCH_SIZE=50
DISPATCHER_LOCK_TTL_SECONDS=60
DISPATCHER_MAX_ATTEMPTS=25
DISPATCHER_CONCURRENCY=10
DISPATCHER_METRICS_ENABLED=true
DISPATCHER_METRICS_HOST=0.0.0.0
DISPATCHER_METRICS_PORT=9091
DISPATCHER_CLIENT_CERT=
DISPATCHER_CLIENT_KEY=
DISPATCHER_CA_CERT=

AGENT_HOST=0.0.0.0
AGENT_PORT=8070
AGENT_ROLE=TRANSIT
AGENT_AUTH_TOKEN=REPLACE_ME
AGENT_DATA_ROOT=/tmp/tracegate-agent
AGENT_STATS_URL=http://127.0.0.1:9999/traffic
AGENT_STATS_SECRET=REPLACE_ME
AGENT_DRY_RUN=true
AGENT_RUNTIME_MODE=systemd
AGENT_RUNTIME_PROFILE=tracegate-2.2
AGENT_XRAY_API_ENABLED=false
AGENT_XRAY_API_SERVER=127.0.0.1:8080
# Graceful Xray hot-reload (no hard restarts), serialized with flock.
AGENT_RELOAD_XRAY_CMD=sh -lc '(flock 9; sleep 1; pkill -HUP xray || true) 9>/tmp/xray-reload.lock'
AGENT_RELOAD_HYSTERIA_CMD=
AGENT_RELOAD_OBFUSCATION_CMD=
AGENT_SERVER_CERT=
AGENT_SERVER_KEY=
AGENT_CA_CERT=

BOT_TOKEN=
BOT_API_BASE_URL=http://localhost:8080
BOT_API_TOKEN=REPLACE_ME
USERS_AUTO_PRUNE_EMPTY=true

DEFAULT_TRANSIT_HOST=transit.example.com
DEFAULT_ENTRY_HOST=entry.example.com

# Client config material
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
REALITY_PUBLIC_KEY_TRANSIT=
REALITY_SHORT_ID_TRANSIT=
REALITY_PUBLIC_KEY_ENTRY=
REALITY_SHORT_ID_ENTRY=
REALITY_PRIVATE_KEY_TRANSIT=
REALITY_PRIVATE_KEY_ENTRY=
REALITY_DEST=splitter.wb.ru:443
REALITY_DEST_TRANSIT=
REALITY_DEST_ENTRY=
REALITY_SERVER_NAME_TRANSIT=
REALITY_SERVER_NAME_ENTRY=
TRANSIT_TLS_SERVER_NAME=
ENTRY_TLS_SERVER_NAME=
HYSTERIA_UDP_PORT=8443
HYSTERIA_SALAMANDER_PASSWORD_ENTRY=
HYSTERIA_SALAMANDER_PASSWORD_TRANSIT=
HYSTERIA_STATS_SECRET_ENTRY=
HYSTERIA_STATS_SECRET_TRANSIT=
# Legacy xray-centric only.
HYSTERIA_BOOTSTRAP_PASSWORD=
HYSTERIA_ECH_CONFIG_LIST=
HYSTERIA_ECH_CONFIG_LIST_ENTRY=
HYSTERIA_ECH_CONFIG_LIST_TRANSIT=
HYSTERIA_ECH_FORCE_QUERY=
HYSTERIA_ECH_FORCE_QUERY_ENTRY=
HYSTERIA_ECH_FORCE_QUERY_TRANSIT=

# VLESS WS+TLS (optional)
VLESS_WS_PATH=/ws
VLESS_WS_TLS_PORT=443

# Grafana integration (optional).
GRAFANA_ENABLED=false
GRAFANA_INTERNAL_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_COOKIE_SECRET=
GRAFANA_OTP_TTL_SECONDS=300
GRAFANA_SESSION_TTL_SECONDS=3600

# Stable pseudo-IDs for metrics/Grafana (recommended; if empty falls back to GRAFANA_COOKIE_SECRET or API_INTERNAL_TOKEN).
PSEUDONYM_SECRET=
